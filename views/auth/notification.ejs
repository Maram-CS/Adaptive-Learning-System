<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Notifications | Eduphin</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="/Style/dashboard.css">
    <link rel="stylesheet" href="/Style/notification.css">
</head>
<body>

<div class="page-container">

    <!-- SIDEBAR -->
    <div class="sidebar">
        <div class="logo">
            <img src="/img/logoBleu.png" class="logo-img" alt="logo">
            <span>Eduphin</span>
        </div>
        <div class="menu">
            <ul>
                <li><a href="/courses/All">All Courses</a></li>
                <li><a href="/studentDashboard/">Dashboard</a></li>
                <li><a href="/favoriteCourses/All">Favorite Courses</a></li>
                <li><a href="/profile/Profile-view">My Profile</a></li>
            </ul>
        </div>
        <br> <br> <br> <br> <br>  <br> <br> <br> 
        <a href="/home"><button class="logout" id="logoutBtn"><i class="fas fa-sign-out-alt"></i> Sign out</button></a>
    </div>

    <!-- MAIN CONTENT -->
    <div class="main">

        <!-- HEADER -->
        <div class="main-header">
            <h2>My <span>Notifications</span></h2>
            <div class="header-actions">
                <div class="buttons">
                    <a href="/studentDashboard/" class="btn-back">
                        <i class="fas fa-arrow-left"></i> Back to Dashboard
                    </a>
                </div>
            </div>
        </div>

        <!-- NOTIFICATIONS PAGE CONTENT -->
        <div class="notifications-page">
            <div class="notifications-header">
                <h1>
                    <i class="fas fa-bell"></i>
                    All Notifications
                </h1>
                <div class="notifications-actions">
                    <button class="btn-mark-all" id="markAllBtn">
                        <i class="fas fa-check-double"></i> Mark all as read
                    </button>
                </div>
            </div>

            <div class="filter-buttons">
                <button class="filter-btn active" data-filter="all">All</button>
                <button class="filter-btn" data-filter="unread">Unread</button>
                <button class="filter-btn" data-filter="course">Courses</button>
                <button class="filter-btn" data-filter="quiz">Quizzes</button>
                <button class="filter-btn" data-filter="info">Info</button>
                <button class="filter-btn" data-filter="ai">AI</button>
            </div>

            <div id="notificationsListContainer" class="notifications-list">
                <div class="loading-state">
                    <i class="fas fa-spinner fa-spin"></i> Loading notifications...
                </div>
            </div>

            <div id="pagination" class="pagination"></div>
        </div>

        <!-- FOOTER -->
        <div class="footer">© 2026 Eduphin. All rights reserved.</div>

    </div>
</div>

<script src="/js/notifications.js"></script>
</body>
</html>