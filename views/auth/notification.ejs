<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Notifications | Eduphin</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="/Style/dashboard.css">
    <link rel="stylesheet" href="/Style/notification.css">
</head>
<body>

<div class="page-container">

    <!-- SIDEBAR -->
    <div class="sidebar">
        <div class="logo">
            <img src="/img/logoBleu.png" class="logo-img" alt="logo">
            <span>Eduphin</span>
        </div>
        <div class="menu">
            <ul>
                <li><a href="/courses/All">All Courses</a></li>
                <li><a href="/studentDashboard/">Dashboard</a></li>
                <li><a href="/favoriteCourses/All">Favorite Courses</a></li>
                <li><a href="/profile/Profile-view">My Profile</a></li>
            </ul>
        </div>
        <br> <br> <br> <br> <br>  <br> <br> <br> 
        <a href="/home"><button class="logout" id="logoutBtn"><i class="fas fa-sign-out-alt"></i> Sign out</button></a>
    </div>

    <!-- MAIN CONTENT -->
    <div class="main">

        <!-- HEADER -->
        <div class="main-header">
            <h2>My <span>Notifications</span></h2>
            <div class="header-actions">
                <div class="buttons">
                    <a href="/studentDashboard/" class="btn-back">
                        <i class="fas fa-arrow-left"></i> Back to Dashboard
                    </a>
                </div>
            </div>
        </div>

        <!-- NOTIFICATIONS PAGE CONTENT -->
        <div class="notifications-page">
            <div class="notifications-header">
                <h1>
                    <i class="fas fa-bell"></i>
                    All Notifications
                </h1>
                <div class="notifications-actions">
                    <button class="btn-mark-all" id="markAllBtn">
                        <i class="fas fa-check-double"></i> Mark all as read
                    </button>
                </div>
            </div>

            <div class="filter-buttons">
                <button class="filter-btn active" data-filter="all">All</button>
                <button class="filter-btn" data-filter="unread">Unread</button>
                <button class="filter-btn" data-filter="course">Courses</button>
                <button class="filter-btn" data-filter="quiz">Quizzes</button>
                <button class="filter-btn" data-filter="info">Info</button>
            </div>

            <div id="notificationsListContainer" class="notifications-list">
                <div class="loading-state">
                    <i class="fas fa-spinner fa-spin"></i> Loading notifications...
                </div>
            </div>

            <div id="pagination" class="pagination"></div>
        </div>

        <!-- FOOTER -->
        <div class="footer">© 2026 Eduphin. All rights reserved.</div>

    </div>
</div>

<script>
    let allNotifications = [];
    let currentFilter = 'all';
    let currentPage = 1;
    const itemsPerPage = 15;
    
    // tjin not mn api 3la 7ssab userId mn cookie
    async function fetchNotifications() {
        try {
            const response = await fetch('/api/notifications', {
                credentials: 'include'
            });
            const data = await response.json();
            
            if (data.success) {
                allNotifications = data.notifications;
                renderFilteredNotifications();
            } else {
                showError('Failed to load notifications');
            }
        } catch (error) {
            console.error('Error:', error);
            showError('Connection error');
        }
    }
    //filtre notf
    function getFilteredNotifications() {
        if (currentFilter === 'all') {
            return allNotifications;
        }
        if (currentFilter === 'unread') {
            return allNotifications.filter(n => !n.is_read);
        }
        return allNotifications.filter(n => n.type === currentFilter);
    }
    
    //3ard notf m3a pagination
    function renderFilteredNotifications() {
        const filtered = getFilteredNotifications();
        const totalPages = Math.ceil(filtered.length / itemsPerPage);
        const start = (currentPage - 1) * itemsPerPage;
        const paginated = filtered.slice(start, start + itemsPerPage);
        
        renderNotificationsList(paginated);
        renderPagination(totalPages);
    }
     //display list notf
    function renderNotificationsList(notifications) {
        const container = document.getElementById('notificationsListContainer');
        
        if (!notifications || notifications.length === 0) {
            container.innerHTML = `
                <div class="empty-state-page">
                    <i class="fas fa-bell-slash"></i>
                    <p>No notifications found</p>
                </div>
            `;
            return;
        }
        
        container.innerHTML = notifications.map(notif => `
            <div class="notification-item-page ${!notif.is_read ? 'unread' : ''}" data-id="${notif._id}">
                <div class="notification-icon-page ${notif.type}">
                    ${notif.type === 'course' ? '📘' : (notif.type === 'quiz' ? '📝' : 'ℹ️')}
                </div>
                <div class="notification-content-page">
                    <div class="notification-title-page">${escapeHtml(notif.title)}</div>
                    <div class="notification-message-page">${escapeHtml(notif.message)}</div>
                    <div class="notification-time-page">
                        <i class="far fa-clock"></i> ${formatTime(notif.created_at)}
                    </div>
                </div>
                <button class="notification-delete-page" data-id="${notif._id}">
                    <i class="fas fa-trash-alt"></i>
                </button>
            </div>
        `).join('');
        
        // event t3 bouttons
        document.querySelectorAll('.notification-item-page').forEach(item => {
            item.addEventListener('click', async (e) => {
                if (e.target.closest('.notification-delete-page')) return;
                
                const id = item.dataset.id;
                if (id && item.classList.contains('unread')) {
                    await markAsRead(id);
                    item.classList.remove('unread');
                    // تحديث العداد في الـ Dashboard (اختياري)
                    updateUnreadCount();
                }
            });
        });
        
        // إضافة أحداث الحذف
        document.querySelectorAll('.notification-delete-page').forEach(btn => {
            btn.addEventListener('click', async (e) => {
                e.stopPropagation();
                const id = btn.dataset.id;
                await deleteNotification(id);
            });
        });
    }
    
    // عرض أزرار التصفح
    function renderPagination(totalPages) {
        const container = document.getElementById('pagination');
        
        if (totalPages <= 1) {
            container.innerHTML = '';
            return;
        }
        
        let html = '';
        for (let i = 1; i <= totalPages; i++) {
            html += `<button class="page-btn ${i === currentPage ? 'active' : ''}" data-page="${i}">${i}</button>`;
        }
        container.innerHTML = html;
        
        document.querySelectorAll('.page-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                currentPage = parseInt(btn.dataset.page);
                renderFilteredNotifications();
                window.scrollTo({ top: 0, behavior: 'smooth' });
            });
        });
    }
    
    // تحديث إشعار كمقروء
    async function markAsRead(id) {
        try {
            await fetch(`/api/notifications/${id}/read`, {
                method: 'PUT',
                credentials: 'include'
            });
            // تحديث الحالة في المصفوفة
            const notif = allNotifications.find(n => n._id === id);
            if (notif) notif.is_read = true;
        } catch (error) {
            console.error('Error:', error);
        }
    }
    
    // تحديث كل الإشعارات كمقروءة
    async function markAllAsRead() {
        try {
            await fetch('/api/notifications/read-all', {
                method: 'PUT',
                credentials: 'include'
            });
            
            allNotifications.forEach(n => n.is_read = true);
            renderFilteredNotifications();
            showToast('✓ All notifications marked as read');
            updateUnreadCount();
        } catch (error) {
            console.error('Error:', error);
            showError('Failed to mark all as read');
        }
    }
    
    // حذف إشعار
    async function deleteNotification(id) {
        try {
            await fetch(`/api/notifications/${id}`, {
                method: 'DELETE',
                credentials: 'include'
            });
            
            allNotifications = allNotifications.filter(n => n._id !== id);
            renderFilteredNotifications();
            updateUnreadCount();
            showToast('🗑 Notification deleted');
        } catch (error) {
            console.error('Error:', error);
            showError('Failed to delete notification');
        }
    }
    
    // تحديث عدد الإشعارات غير المقروءة (للتحديث في الـ Dashboard)
    async function updateUnreadCount() {
        try {
            const response = await fetch('/api/notifications/unread-count', {
                credentials: 'include'
            });
            const data = await response.json();
            if (data.success && window.opener) {
                // تحديث العداد في الصفحة الأصلية إذا كانت مفتوحة
                localStorage.setItem('unreadCount', data.unreadCount);
            }
        } catch (error) {
            console.error('Error:', error);
        }
    }
    
    // Helper: تنسيق الوقت
    function formatTime(dateString) {
        const date = new Date(dateString);
        const now = new Date();
        const diffMs = now - date;
        const diffMins = Math.floor(diffMs / 60000);
        const diffHours = Math.floor(diffMs / 3600000);
        const diffDays = Math.floor(diffMs / 86400000);
        
        if (diffMins < 1) return 'Just now';
        if (diffMins < 60) return `${diffMins} minute${diffMins > 1 ? 's' : ''} ago`;
        if (diffHours < 24) return `${diffHours} hour${diffHours > 1 ? 's' : ''} ago`;
        if (diffDays < 7) return `${diffDays} day${diffDays > 1 ? 's' : ''} ago`;
        
        return date.toLocaleDateString();
    }
    
    function escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }
    
    function showToast(message) {
        const toast = document.createElement('div');
        toast.className = 'toast';
        toast.innerHTML = `<i class="fas fa-check-circle"></i> ${message}`;
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 2500);
    }
    
    function showError(message) {
        const toast = document.createElement('div');
        toast.className = 'toast';
        toast.style.background = '#e74c3c';
        toast.innerHTML = `<i class="fas fa-exclamation-circle"></i> ${message}`;
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 2500);
    }
    
    // ============================================
    // EVENT LISTENERS
    // ============================================
    
    function setupEventListeners() {
        // Filter buttons
        document.querySelectorAll('.filter-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                currentFilter = btn.dataset.filter;
                currentPage = 1;
                renderFilteredNotifications();
            });
        });
        
        // Mark all button
        const markAllBtn = document.getElementById('markAllBtn');
        if (markAllBtn) {
            markAllBtn.addEventListener('click', markAllAsRead);
        }
    }
    
    // ============================================
    // INITIALIZATION
    // ============================================
    
    document.addEventListener('DOMContentLoaded', () => {
        fetchNotifications();
        setupEventListeners();
    });
</script>
</body>
</html>