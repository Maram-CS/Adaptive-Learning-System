<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title><%= course.Title %> | Course Details</title>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
<link rel="stylesheet" href="/Style/course.css">

</head>

<body>

<div class="page-container">

<button class="sidebar-hidden-toggle" id="sidebarHiddenToggle">
<i class="fas fa-bars"></i>
</button>

<!-- SIDEBAR -->

<div class="sidebar" id="sidebar">

<div class="logo" id="logoToggle">
<div class="logo-content">
<img src="/img/logoBleu.png" class="logo-img">
<span>My Courses</span>
</div>
<i class="fas fa-chevron-left toggle-icon"></i>
</div>

<div class="menu">
<ul>

<li><a href="/courses/All">All Courses</a></li>
<li><a href="/studentDashboard/">Dashboard</a></li>
<li><a href="/favoriteCourses/All">Favorite Courses</a></li>
<li><a href="/profile/Profile-view">My Profile</a></li>

</ul>
</div>

<a href="/home">
<button class="logout" id="logoutBtn"><i class="fas fa-sign-out-alt"></i> Sign out</button>
</a>

</div>

<!-- MAIN -->

<div class="main" id="mainContent">

<div class="main-header">
<h2>Course <span>Details</span></h2>
</div>

<div class="course-container">

<!-- HEADER -->

<div class="course-header">

<h1><%= course.Title %></h1>

<div class="course-meta">

<span>
<i class="fas fa-chalkboard-user"></i>
<%= course.Instructor?.userName || "Instructor" %>
</span>

<span>
<i class="fas fa-star" style="color: var(--orange);"></i>
4.8 (245 ratings)
</span>

<span>
<i class="fas fa-book"></i>
<%= course.lessons?.length || 0 %> lessons
</span>

</div>

<p class="course-description">
<%= course.Description %>
</p>

  <!-- PLACEMENT QUIZ SECTION -->

<div class="quiz-section">

<h3>
<i class="fas fa-brain"></i>
Placement Quiz
</h3>

<p>
Take this quiz to determine your level and unlock personalized lessons
</p>

<% course.quizzes.forEach(quiz => { %>

    <a href="/quiz/course/<%= course._id %>/quiz/<%= quiz._id %>">
        <button class="quiz-btn">
            Start Quiz - <%= quiz.title %>
        </button>
    </a>

<% }) %>

<button class="quiz-btn">
Start Placement Quiz
</button>

</a>

</div>

<div class="progress-section">
<div class="progress-label">
<span>Your Progress</span>
<span><strong id="progressPercent">0%</strong></span>
</div>

<div class="progress-bar">
<div class="progress-fill" id="progressFill"></div>
</div>

</div>

</div>

<div class="stats-full-width">

<h3>
<i class="fas fa-chart-simple"></i>
Quick Stats
</h3>

<div class="stats-grid">

<div class="stat-item">
<i class="fas fa-check-circle"></i>
<span>Lessons Completed</span>
<strong id="completedCount">0</strong>
</div>

<div class="stat-item">
<i class="fas fa-fire"></i>
<span>Current Streak</span>
<strong>5 days</strong>
</div>

<div class="stat-item">
<i class="fas fa-hourglass-half"></i>
<span>Time Spent</span>
<strong id="timeSpent">0h</strong>
</div>

<div class="stat-item">
<i class="fas fa-trophy"></i>
<span>Quiz Average</span>
<strong>0%</strong>
</div>

</div>

</div>

<div class="content-section">

<h2 class="section-title">
<i class="fas fa-list"></i>
Course Content
</h2>

<% if(course.lessons && course.lessons.length > 0){ %>

<% course.lessons.forEach((lesson,index)=>{ %>

<div class="lesson-item" data-progress="0">

<div class="lesson-info">

<i class="fas fa-play-circle"></i>

<div>

<h4>
Lesson <%= index + 1 %> :
<%= lesson.name %>
</h4>

<p>
<%= lesson.type || "Video" %>
</p>

</div>

</div>

<div class="lesson-progress">
0%
</div>

<button
class="btn-continue"
onclick="startLesson('<%= lesson.file %>')"

>

<i class="fas fa-play"></i>
Start </button>

</div>

<% }) %>

<% }else{ %>

<p>No lessons available</p>

<% } %>

</div>

</div>

</div>

</div>

<script>

const lessons = document.querySelectorAll(".lesson-item")

function startLesson(file){

window.open(file,"_blank")

}

</script>

<script src="/js/course-details.js"></script>

</body>
</html>
