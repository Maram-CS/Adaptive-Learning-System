 <!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Student Profile</title>
  <link rel="stylesheet" href="/Style/Profile.css">
</head>
<body>

<div class="container">

  <!-- Sidebar -->
  <div class="sidebar">
    <h3 class="logo">My Profile</h3>

    <ul>
      <li class="active">My Profile</li>
      <li><a href="/App/studentDashboard">Dashboard</a></li>
      <li><a href="/courses/All">All Courses</a></li>
      <li><a href="/favoriteCourses/All">Favorite Courses</a></li>
    </ul>

    <a href="/home"><button class="logout">Sign out</button></a>
  </div>

  <!-- Main Content -->
  <div class="main">

    <h2>Student <span>Profile</span></h2>

    <!-- الفورم تحتوي على كل المحتوى -->
    <form class="profile-form" method="POST" action="/profile/edit" enctype="multipart/form-data">
      
      <!-- صورة المستخدم والـ Bio داخل الفورم -->
      <div class="profile-header">
        <div class="profile-info">
          <div class="avatar-container">
            <img id="profileImage" class="avatar" src="https://via.placeholder.com/90" alt="Profile">
            <input type="file" id="imageUpload" accept="image/*" style="display: none;" name="profilePicture">
          </div>
          
          <div class="user-details">
            <input type="text" class="username-input" placeholder="Enter username" value="frontend developer" name="username">
            <textarea class="bio-input" placeholder="Write a short bio..." name="bio">Frontend developer passionate about creating beautiful and responsive web applications</textarea>
          </div>
        </div>

        <div class="header-buttons">
          <button type="button" class="upload" onclick="document.getElementById('imageUpload').click();">Upload New Photo</button>
          <button type="button" class="delete" id="deleteImage">Delete</button>
        </div>
      </div>
      
      <!-- Personal Information Box -->
      <div class="info-box">
        <div class="box-header">
          <h3 class="box-title">Personal Information</h3>
          <span class="box-icon">👤</span>
        </div>
        <div class="box-content">
          <div class="row">
            <div class="input-group">
              <label>First Name</label>
              <input type="text" placeholder="Enter first name" name="firstName">
            </div>

            <div class="input-group">
              <label>Last Name</label>
              <input type="text" placeholder="Enter last name" name="lastName">
            </div>
          </div>

          <div class="input-group">
            <label>User Name</label>
            <input type="text" placeholder="Enter username" name="userName">
          </div>

          <div class="row">
            <div class="input-group">
              <label>Email Address</label>
              <input type="email" placeholder="Enter email" name="email">
            </div>

            <div class="input-group">
              <label>Phone Number</label>
              <input type="text" placeholder="Enter phone number" name="PhoneNumber">
            </div>
          </div>
        </div>
      </div>

      <!-- Skills & Track Box -->
      <div class="info-box">
        <div class="box-header">
          <h3 class="box-title">Skills & Track</h3>
          <span class="box-icon">⚡️</span>
        </div>
        <div class="box-content">
          <div class="row">
            <div class="input-group">
              <label>Main track</label>
              <select name="mainTrack">
                <option>- Select main track -</option>
                <option>Web Development</option>
                <option>Mobile Development</option>
                <option>Frontend Development</option>
                <option>Backend Development</option>
                <option>Full Stack Development</option>
                <option>DevOps</option>
                <option>Cloud Computing</option>
              </select>
            </div>

            <div class="input-group">
 <label>Skill level</label>
              <select name="skillLevel">
                <option>- Select skill level -</option>
                <option>Beginner</option>
                <option>Intermediate</option>
                <option>Advanced</option>
                <option>Expert</option>
              </select>
            </div>
          </div>
        </div>
      </div>

      <div class="form-buttons">
        <button type="button" class="cancel">Cancel</button>
        <button type="submit" class="save">Save</button>
      </div>

    </form>
     <!-- FOOTER -->
        <div class="footer">© 2026 Eduphin. All Rights Reserved.</div>


  </div>

</div>

<script>
  // JavaScript for image upload
  document.getElementById('imageUpload').addEventListener('change', function(event) {
    const file = event.target.files[0];
    if (file) {
      const reader = new FileReader();
      reader.onload = function(e) {
        document.getElementById('profileImage').src = e.target.result;
      }
      reader.readAsDataURL(file);
    }
  });

  // Delete image
  document.getElementById('deleteImage').addEventListener('click', function() {
    document.getElementById('profileImage').src = 'https://via.placeholder.com/90';
    document.getElementById('imageUpload').value = '';
  });


</script>
<% if (typeof error !== "undefined") { %>
<script>
  alert("<%= error %>");
</script>
<% } %>
</body>
</html>