<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Eduphin | Teacher Dashboard</title>
    <link rel="stylesheet" href="/Style/teacherdashboard.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>

<div class="page-container">

    <!-- SIDEBAR  -->
    <div class="sidebar">
        <div class="logo">
            <img src="/img/logoBleu.png" class="logo-img" alt="logo">
            <span>Eduphin</span>
        </div>
        <div class="menu">
            <ul>
                <li class="active">Home</li>
                  <li><a href="/profile/Profile-view">My Profile</a></li>
                <li><a href="#">Create Quiz </a></li>
                 <li><a href="/App/createCourse">Create Course </a></li>
                <li><a href="#">Student Analytics</a></li>
            </ul>
        </div>
       <br> <br> <br> <br> <br>  
        <a href="/home">
    <button class="logout">Sign out</button>
</a>
    </div>

    <!-- MAIN CONTENT -->
    <div class="main">

        <!-- HEADER -->
        <div class="main-header">
            <h2>Teacher <span>Dashboard</span></h2>
            <div class="header-actions">
                <input type="text" id="searchInput" class="search-bar" placeholder="Search for courses...">
                <div class="buttons">
                   <a href="/profile/Profile-view"><button class="icon-btn" onclick="getProfile">👤</button></a>
                </div> 
    </div>
</div>
<br>
<!-- Welcome -->
    <div class="welcome">
      <div>
        <h2>Welcome, Professor
        <%= user.userName %> 👋 </h2>
        <p>Shape the future of learning by building interactive courses, <br> adapting content to every student, and unlocking powerful insights.</p>
      </div>
    </div>
    
    <!-- Overview -->
    <h3>Overview</h3>

<div class="dashboard-container">

  <div class="cards">

    <!-- CARD 1 -->
    <div class="card">
      <div class="feature-icon icon-blue">
        <i class="fa-solid fa-book"></i>
      </div>
      <h4> <span class="orange">Total</span> <span class="blue">Courses</span></h4>
      <p class="big"></p>
    </div>

    <!-- CARD 2 -->
    <div class="card">
      <div class="feature-icon icon-orange">
        <i class="fa-solid fa-clipboard-list"></i>
      </div>
      <h4> <span class="orange"> Quiz</span> <span class="blue"> Repository</span></h4>
      <p class="big"></p>
    </div>

    <!-- CARD 3 -->
    <div class="card">
      <div class="feature-icon icon-cryan">
        <i class="fa-solid fa-users"></i>
      </div>
      <h4><span class="orange">Total</span> <span class="blue">Students</span></h4>
      <p class="big"></p>
       <a href="">  <button class="btn-student">View All students</button></a>
    </div>

  </div>
</div>
  

    <!-- Courses -->
    <h3>Course Section</h3>
    <div class="courses">

      <div class="course">
        <h4>Mastering Full-Stack</h4>
        <div class="buttons">
          <button>Edit Course</button>
          <button>Quiz Hub</button>
        </div>
        <div class="buttons second">
          <button class="orange">Student Performance</button>
          <button class="orange">Content</button>
        </div>
        <div class="progress"><span style="width:40%"></span></div>
        <p>42 enrolled students</p>
      </div>

      <div class="course">
        <h4>Data Science Track</h4>
        <div class="buttons">
          <button>Edit Course</button>
          <button>Quiz Hub</button>
        </div>
        <div class="buttons second">
          <button class="orange">Student Performance</button>
          <button class="orange">Content</button>
        </div>
        <div class="progress"><span style="width:60%"></span></div>
        <p>47 enrolled students</p>
      </div>

      <div class="course">
        <h4>Mobile Dev Specialization</h4>
        <div class="buttons">
          <button>Edit Course</button>
          <button>Quiz Hub</button>
        </div>
        <div class="buttons second">
          <button class="orange">Student Performance</button>
          <button class="orange">Content</button>
        </div>
        <div class="progress"><span style="width:60%"></span></div>
        <p>47 enrolled students</p>
      </div>

    </div>
    <!-- FOOTER -->
        <div class="footer">© 2026 Eduphin. All Rights Reserved.</div>


  </main>

</div>
<script>
    // Example dynamic name
document.getElementById("teacherName").innerText = "John Doe";

// Sidebar active effect
const items = document.querySelectorAll(".sidebar li");

items.forEach(item => {
  item.addEventListener("click", () => {
    items.forEach(i => i.classList.remove("active"));
    item.classList.add("active");
  });
});

const getProfile = () => {
  window.location.href = "/profile/Profile-view";
};

</script>

</body>
</html>