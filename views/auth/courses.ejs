<script>
/* ── RATING TEXT ─────────────────────────────────── */
const ratingText = {
  0: 'Tap to rate',
  1: 'Poor',
  2: 'Fair',
  3: 'Good',
  4: 'Very Good',
  5: 'Excellent! 🎉'
};

/* ── FAVORITES ───────────────────────────────────── */
function getFavorites() {
  try { return JSON.parse(localStorage.getItem('favorites') || '[]'); }
  catch { return []; }
}

function toggleFavorite(courseId, btn) {
  let favs = getFavorites();
  const idx = favs.indexOf(courseId);
  if (idx === -1) {
    favs.push(courseId);
    btn.classList.add('active');
    showToast('❤️ Added to favorites!');
  } else {
    favs.splice(idx, 1);
    btn.classList.remove('active');
    showToast('💔 Removed from favorites');
  }
  localStorage.setItem('favorites', JSON.stringify(favs));
}

/* Sync heart states from localStorage on page load */
function syncHearts() {
  const favs = getFavorites();
  document.querySelectorAll('.heart-btn').forEach(btn => {
    const courseId = btn.getAttribute('data-id');
    btn.classList.toggle('active', favs.includes(courseId));
  });
}

/* ── TOAST ───────────────────────────────────────── */
function showToast(msg) {
  const toast = document.getElementById('favToast');
  toast.textContent = msg;
  toast.classList.add('show');
  setTimeout(() => toast.classList.remove('show'), 2200);
}

/* ── BUILD STARS FOR ONE CARD ────────────────────── */
function buildStars(container) {
  const course   = container.getAttribute('data-course');
  const saved    = parseInt(localStorage.getItem('rating_' + course)) || 0;
  const label    = container.nextElementSibling;

  container.innerHTML = '';

  for (let i = 1; i <= 5; i++) {
    const star = document.createElement('span');
    star.classList.add('star');
    star.textContent = '★';
    star.dataset.value = i;
    if (i <= saved) star.classList.add('filled');

    star.addEventListener('mouseenter', () => {
      const val = parseInt(star.dataset.value);
      highlightStars(container, val);
      label.textContent = ratingText[val];
      label.classList.remove('rated');
    });

    star.addEventListener('mouseleave', () => {
      const cur = parseInt(localStorage.getItem('rating_' + course)) || 0;
      highlightStars(container, cur);
      label.textContent = ratingText[cur];
      label.classList.toggle('rated', cur > 0);
    });

    star.addEventListener('click', () => {
      const val = parseInt(star.dataset.value);
      localStorage.setItem('rating_' + course, val);
      highlightStars(container, val);
      label.textContent = ratingText[val];
      label.classList.add('rated');

      star.style.transform = 'scale(1.6)';
      setTimeout(() => { star.style.transform = ''; }, 220);
    });

    container.appendChild(star);
  }

  highlightStars(container, saved);
  label.textContent  = ratingText[saved];
  label.classList.toggle('rated', saved > 0);
}

function highlightStars(container, value) {
  container.querySelectorAll('.star').forEach(s => {
    s.classList.toggle('filled', parseInt(s.dataset.value) <= value);
  });
}

/* ── VIEW COURSE DETAILS FUNCTION ────────────────── */
function viewCourseDetails(title) {
  localStorage.setItem('selectedCourse', title);
  window.location.href = `/App/course`;
}

/* ── INIT ────────────────────────────────────────── */
document.querySelectorAll('.star-rating').forEach(buildStars);
syncHearts();

/* ── SEARCH ──────────────────────────────────────── */
const searchInput = document.getElementById('searchInput');
const items = document.querySelectorAll('.item');

searchInput.addEventListener('keyup', function () {
  const filter = searchInput.value.toLowerCase();
  items.forEach(item => {
    item.style.display = item.textContent.toLowerCase().includes(filter) ? 'flex' : 'none';
  });
});

/* ── CATEGORY FILTER ─────────────────────────────── */
function filterCourses(category, btn) {
  document.querySelectorAll('.filter-buttons button').forEach(b => b.classList.remove('active-filter'));
  btn.classList.add('active-filter');
  items.forEach(item => {
    const cat = item.getAttribute('data-category');
    item.style.display = (category === 'all' || cat === category) ? 'flex' : 'none';
  });
}
</script>

