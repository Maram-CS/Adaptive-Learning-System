<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Dashboard | Adaptive Learning Platform</title>
    <link rel="stylesheet" href="../Style/dashboard.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>

<div class="page-container">

    <!-- SIDEBAR -->
    <div class="sidebar">
        <div class="logo">
            <img src="/img/logoBleu.png" class="logo-img" alt="logo">
            <span>Eduphin</span>
        </div>
        <div class="menu">
            <ul>
                <li><a href="/App/courses">All Courses</a></li>
                <li class="active"><a href="/App/studentDashboard">Dashboard</a></li>
                <li><a href="/App/favoriteCourses">Favorite Courses</a></li>
                <li><a href="/App/infoProfile">My Profile</a></li>
            </ul>
        </div>
        <a href="/home"><button class="logout">Sign out</button></a>
    </div>

    <!-- MAIN CONTENT -->
    <div class="main">

        <!-- HEADER -->
        <div class="main-header">
            <h2>Student <span>Dashboard</span></h2>
            <div class="header-actions">
                <input type="text" id="searchInput" class="search-bar" placeholder="Search courses...">
                <div class="buttons">
                    <button class="icon-btn">🔔</button>
                    <button class="icon-btn">💬</button>
                    <a href="/App/infoProfile"><button class="icon-btn">👤</button></a>
                </div>
            </div>
        </div>

        <!-- DASHBOARD CONTENT (Dynamic) -->
        <div id="dashboard-container"></div>

        <!-- FOOTER -->
        <div class="footer">© 2026 Eduphin. All rights reserved.</div>

    </div>
</div>

<script>
    // ============================================
    // STUDENT DASHBOARD DATA
    // ============================================
    const userData = {
        firstName: "Ahmed",
        streakDays: 5,
        totalLearningHours: 4,
        totalLearningMinutes: 20,
        quizAverage: 85
    };

    const courses = [
        {
            id: 1,
            title: "Full-Stack Development",
            icon: "fab fa-react",
            overallProgress: 40,
            lastLesson: "React Hooks",
            lastLessonTime: 15,
            lessons: [
                { title: "JavaScript Basics", progress: 100, completed: true, icon: "fab fa-js" },
                { title: "DOM Manipulation", progress: 100, completed: true, icon: "fas fa-window-maximize" },
                { title: "React Components", progress: 60, completed: false, icon: "fab fa-react" },
                { title: "React Hooks", progress: 45, completed: false, icon: "fab fa-react" },
                { title: "State Management", progress: 25, completed: false, icon: "fas fa-database" },
                { title: "API Integration", progress: 0, completed: false, icon: "fas fa-plug" }
            ]
        },
        {
            id: 2,
            title: "Python for Data Science",
            icon: "fab fa-python",
            overallProgress: 60,
            lastLesson: "Pandas",
            lastLessonTime: 10,
            lessons: [
                { title: "Python Basics", progress: 100, completed: true, icon: "fab fa-python" },
                { title: "NumPy", progress: 100, completed: true, icon: "fas fa-calculator" },
                { title: "Pandas", progress: 70, completed: false, icon: "fas fa-table" },
                { title: "Data Visualization", progress: 30, completed: false, icon: "fas fa-chart-line" },
                { title: "Machine Learning Intro", progress: 0, completed: false, icon: "fas fa-brain" }
            ]
        },
        {
            id: 3,
            title: "Mobile App Development (Flutter)",
            icon: "fab fa-android",
            overallProgress: 20,
            lastLesson: "Flutter Basics",
            lastLessonTime: 25,
            lessons: [
                { title: "Flutter Basics", progress: 50, completed: false, icon: "fab fa-flutter" },
                { title: "Widgets", progress: 20, completed: false, icon: "fas fa-puzzle-piece" },
                { title: "State Management", progress: 0, completed: false, icon: "fas fa-database" },
                { title: "Navigation", progress: 0, completed: false, icon: "fas fa-directions" }
            ]
        }
    ];

    const recommendations = [
        { icon: "fas fa-code", title: "JavaScript Arrays", reason: "Based on your last quiz performance" },
        { icon: "fab fa-react", title: "React Components", reason: "Next in your Full-Stack path" },
        { icon: "fab fa-python", title: "Pandas Tutorial", reason: "Popular among learners this week" }
    ];

    const leaderboard = [
        { name: "Sarah", points: 1250, badge: "🔥", isCurrentUser: false },
        { name: "Ahmed", points: 980, badge: "⭐", isCurrentUser: true },
        { name: "Youssef", points: 745, badge: "📈", isCurrentUser: false },
        { name: "Leila", points: 620, badge: "", isCurrentUser: false },
        { name: "Omar", points: 510, badge: "", isCurrentUser: false }
    ];

    // ============================================
    // FUNCTIONS
    // ============================================
    function showToast(message) {
        const toast = document.createElement('div');
        toast.className = 'toast';
        toast.innerHTML = `<i class="fas fa-info-circle"></i> ${message}`;
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 2500);
    }

    function toggleLessons(courseId) {
        const lessonsDiv = document.getElementById(`lessons-${courseId}`);
        const icon = document.getElementById(`expand-icon-${courseId}`);
        if (lessonsDiv) {
            lessonsDiv.classList.toggle('show');
            if (icon) {
                icon.classList.toggle('rotated');
            }
        }
    }

    function continueLesson(lessonTitle, courseTitle) {
        showToast(`📚 Continuing: ${lessonTitle} from ${courseTitle}`);
    }

    function animateNumbers() {
        const numbers = document.querySelectorAll('.stat-number');
        numbers.forEach(el => {
            const target = parseInt(el.getAttribute('data-target'));
            let current = 0;
            const increment = target / 50;
            const updateNumber = () => {
                current += increment;
                if (current < target) {
                    el.textContent = Math.floor(current);
                    requestAnimationFrame(updateNumber);
                } else {
                    el.textContent = target;
                }
            };
            updateNumber();
        });
    }

    function renderDashboard() {
        const container = document.getElementById('dashboard-container');
        
        const totalLessons = courses.reduce((sum, c) => sum + c.lessons.length, 0);
        const completedLessons = courses.reduce((sum, c) => sum + c.lessons.filter(l => l.completed).length, 0);
        const avgProgress = Math.round(courses.reduce((sum, c) => sum + c.overallProgress, 0) / courses.length);
        
        container.innerHTML = `
            <!-- Welcome Card -->
            <div class="welcome-card">
                <div class="welcome-text">
                    <h1><i class="fas fa-smile-wink"></i> Hello, ${userData.firstName}!</h1>
                    <p>You are enrolled in <strong>${courses.length} courses</strong><br>Click on any course to see its lessons.</p>
                </div>
                <div class="streak-badge" onclick="showToast('🔥 You're on a ${userData.streakDays}-day streak!')">
                    <i class="fas fa-fire"></i> Day ${userData.streakDays} 🔥
                </div>
            </div>

            <!-- Progress + Recommendations Row -->
            <div class="dashboard-grid-2">
                <div class="dashboard-card">
                    <div class="card-header">
                        <i class="fas fa-chart-line"></i>
                        <h3>Overall Progress</h3>
                    </div>
                    <div class="progress-label">
                        <span>All Courses</span>
                        <span><strong>${avgProgress}%</strong></span>
                    </div>
                    <div class="progress-bar">
                        <div class="progress-fill" style="width: ${avgProgress}%"></div>
                    </div>
                    <p><i class="fas fa-check-circle"></i> ${completedLessons}/${totalLessons} lessons completed</p>
                </div>

                <div class="dashboard-card">
                    <div class="card-header">
                        <i class="fas fa-lightbulb"></i>
                        <h3>Smart Recommendations</h3>
                    </div>
                    <ul class="recommendations-list">
                        ${recommendations.map(rec => `
                            <li onclick="showToast('📚 Recommended: ${rec.title}')">
                                <i class="${rec.icon}"></i> 
                                <strong>${rec.title}</strong> – ${rec.reason}
                            </li>
                        `).join('')}
                    </ul>
                </div>
            </div>

            <!-- Stats Grid -->
            <div class="stats-grid">
                <div class="stat-card" onclick="showToast('📖 ${completedLessons} lessons completed')">
                    <i class="fas fa-book-open"></i>
                    <div class="stat-number" data-target="${completedLessons}">0</div>
                    <div class="stat-label">Lessons Done</div>
                </div>
                <div class="stat-card" onclick="showToast('🔥 ${userData.streakDays}-day streak!')">
                    <i class="fas fa-fire"></i>
                    <div class="stat-number" data-target="${userData.streakDays}">0</div>
                    <div class="stat-label">Day Streak</div>
                </div>
                <div class="stat-card" onclick="showToast('⏱️ ${userData.totalLearningHours}h ${userData.totalLearningMinutes}m')">
                    <i class="fas fa-hourglass-half"></i>
                    <div class="stat-number" data-target="${userData.totalLearningHours}">0</div>
                    <div class="stat-label">Learning Hours</div>
                </div>
                <div class="stat-card" onclick="showToast('📊 ${userData.quizAverage}% average')">
                    <i class="fas fa-chart-simple"></i>
                    <div class="stat-number" data-target="${userData.quizAverage}">0</div>
                    <div class="stat-label">Quiz Average</div>
                </div>
            </div>

            <!-- Courses Section -->
            <div class="dashboard-card courses-section">
                <div class="card-header">
                    <i class="fas fa-graduation-cap"></i>
                    <h3>My Courses (${courses.length})</h3>
                </div>
                ${courses.map(course => `
                    <div class="course-card" onclick="toggleLessons(${course.id})">
                        <div class="course-header">
                            <div class="course-title">
                                <i class="${course.icon}"></i> 
                                <strong>${course.title}</strong>
                            </div>
                            <div class="course-progress-badge">${course.overallProgress}%</div>
                        </div>
                        <div class="progress-bar">
                            <div class="progress-fill" style="width: ${course.overallProgress}%"></div>
                        </div>
                        <div class="last-lesson">
                            <i class="fas fa-clock"></i> Last: ${course.lastLesson} — ${course.lastLessonTime} min left
                        </div>
                        <div class="course-actions">
                            <button class="continue-btn" onclick="event.stopPropagation(); showToast('📚 Continue ${course.title}')">
                                <i class="fas fa-play"></i> Continue Course
                            </button>
                            <i id="expand-icon-${course.id}" class="fas fa-chevron-right expand-icon"></i>
                        </div>
                        
                        <div id="lessons-${course.id}" class="lessons-container">
                            <div class="lessons-header"><i class="fas fa-list"></i> Lessons in this course</div>
                            ${course.lessons.map(lesson => `
                                <div class="lesson-item" onclick="event.stopPropagation(); continueLesson('${lesson.title}', '${course.title}')">
                                    <div class="lesson-title">
                                        <span><i class="${lesson.icon}"></i> <strong>${lesson.title}</strong></span>
                                        ${lesson.completed ? '<span class="completed-badge"><i class="fas fa-check"></i> Done</span>' : `<span>${lesson.progress}%</span>`}
                                    </div>
                                    <div class="progress-bar">
                                        <div class="progress-fill" style="width: ${lesson.progress}%"></div>
                                    </div>
                                    ${!lesson.completed ? `
                                        <button class="small-continue-btn" onclick="event.stopPropagation(); continueLesson('${lesson.title}', '${course.title}')">
                                            <i class="fas fa-play"></i> ${lesson.progress > 0 ? 'Continue' : 'Start'} Lesson
                                        </button>
                                    ` : ''}
                                </div>
                            `).join('')}
                        </div>
                    </div>
                `).join('')}
            </div>

            <!-- Leaderboard + Today's Path -->
            <div class="dashboard-grid-2">
                <div class="dashboard-card">
                    <div class="card-header"><i class="fas fa-trophy"></i><h3>Weekly Leaderboard</h3></div>
                    <table class="leaderboard-table">
                        <thead><tr><th>Rank</th><th>Student</th><th>Points</th></tr></thead>
                        <tbody>
                            ${leaderboard.map((item, idx) => `
                                <tr class="${item.isCurrentUser ? 'current-user' : ''}" onclick="showToast('${item.name}: ${item.points} pts')">
                                    <td>${idx === 0 ? '🥇' : idx === 1 ? '🥈' : idx === 2 ? '🥉' : idx+1}</td>
                                    <td><strong>${item.name}${item.isCurrentUser ? ' (You)' : ''}</strong></td>
                                    <td>${item.points}</td>
                                </tr>
                            `).join('')}
                        </tbody>
                    </table>
                </div>
                <div class="dashboard-card">
                    <div class="card-header"><i class="fas fa-calendar-day"></i><h3>Today's Learning Path</h3></div>
                    <ul class="today-path-list">
                        <li><i class="fas fa-code"></i> <strong>Full-Stack:</strong> React Hooks (15 min)</li>
                        <li><i class="fas fa-chart-line"></i> <strong>Data Science:</strong> Pandas Tutorial</li>
                        <li><i class="fas fa-mobile-alt"></i> <strong>Flutter:</strong> Widgets Basics</li>
                    </ul>
                </div>
            </div>

            <!-- Upcoming Assessments -->
            <div class="dashboard-card">
                <div class="card-header"><i class="fas fa-calendar-alt"></i><h3>Upcoming Assessments</h3></div>
                <ul class="assessments-list">
                    <li><i class="fas fa-clock"></i> <strong>Tomorrow:</strong> JavaScript Functions Quiz (Full-Stack)</li>
                    <li><i class="fas fa-clock"></i> <strong>In 3 days:</strong> Final Project – Calculator App (Full-Stack)</li>
                    <li><i class="fas fa-clock"></i> <strong>Next week:</strong> Pandas Quiz (Python for Data Science)</li>
                </ul>
            </div>
        `;
        
        setTimeout(animateNumbers, 500);
    }

    renderDashboard();
</script>
</body>
</html>