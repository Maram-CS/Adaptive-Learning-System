<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Eduphin | Course Content Manager</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,400&display=swap" rel="stylesheet">
    <style>
    /* ========== EXACT SAME COLORS & STYLES FROM CREATE COURSE ========== */
    :root {
        --bg: #0d0d14;
        --surface: #141420;
        --surface2: #1c1c2a;
        --border: #262636;
        --accent: #4F46E5;
        --accent-glow: rgba(79,70,229,.2);
        --green: #00d97e;
        --orange: #f79c42;
        --red: #ff6b6b;
        --text: #e4e4f0;
        --muted: #60607a;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
        font-family: 'DM Sans', sans-serif;
        background: var(--bg);
        color: var(--text);
        min-height: 100vh;
    }

    /* PAGE CONTAINER */
    .page-container { display: flex; min-height: 100vh; }

    /* ========== SIDEBAR (exactly like createCourse) ========== */
    .sidebar {
        width: 280px;
        background: var(--surface);
        border-right: 1px solid var(--border);
        padding: 30px 24px;
        display: flex;
        flex-direction: column;
        gap: 32px;
        position: sticky;
        top: 0;
        height: 100vh;
        overflow-y: auto;
    }

    .logo {
        display: flex;
        align-items: center;
        gap: 12px;
        font-family: 'Syne', sans-serif;
        font-weight: 800;
        font-size: 1.4rem;
        letter-spacing: -0.3px;
    }
    .logo-img {
        width: 42px;
        height: auto;
        filter: drop-shadow(0 2px 6px rgba(0,0,0,0.3));
    }
    .logo span {
        background: linear-gradient(135deg, #fff, #a0a0ff);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
    }

    .menu ul {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 6px;
    }
    .menu ul li {
        padding: 10px 14px;
        border-radius: 12px;
        cursor: pointer;
        font-weight: 500;
        font-size: 14px;
        color: #9ca3af;
        transition: all 0.2s;
    }
    .menu ul li.active {
        background: var(--accent);
        color: white;
    }
    .menu ul li a {
        text-decoration: none;
        color: inherit;
        display: flex;
        align-items: center;
        gap: 12px;
    }
    .menu ul li a i { width: 20px; }
    .menu ul li:hover:not(.active) {
        background: var(--surface2);
        color: var(--text);
    }

    .logout {
        margin-top: auto;
        background: var(--orange);
        border: none;
        padding: 12px 20px;
        border-radius: 40px;
        color: #0c1e36;
        font-weight: 700;
        cursor: pointer;
        font-size: 14px;
        transition: all 0.3s;
        width: 100%;
        text-align: center;
        text-decoration: none;
        display: inline-block;
    }
    .logout i { margin-right: 8px; }
    .logout:hover {
        background: var(--accent);
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 6px 14px rgba(79,70,229,0.3);
    }

    /* ========== MAIN CONTENT (same colors) ========== */
    .main {
        flex: 1;
        padding: 32px 44px;
        overflow-y: auto;
        background: var(--bg);
    }

    .main-header {
        background: var(--surface);
        border-radius: 20px;
        padding: 24px 32px;
        margin-bottom: 28px;
        border: 1px solid var(--border);
    }
    .main-header h2 {
        font-family: 'Syne', sans-serif;
        font-size: 28px;
        font-weight: 800;
        letter-spacing: -0.5px;
    }
    .main-header h2 span { color: var(--accent); }
    .breadcrumb {
        color: var(--muted);
        font-size: 13px;
        margin-top: 8px;
    }
    .breadcrumb a {
        color: var(--accent);
        text-decoration: none;
    }

    /* TABS */
    .tabs {
        display: flex;
        gap: 8px;
        margin-bottom: 28px;
        background: var(--surface);
        border-radius: 14px;
        padding: 6px;
        width: fit-content;
        border: 1px solid var(--border);
    }
    .tab-btn {
        padding: 10px 24px;
        border-radius: 10px;
        border: none;
        background: transparent;
        color: var(--muted);
        font-family: 'DM Sans', sans-serif;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .tab-btn.active {
        background: var(--accent);
        color: white;
    }
    .tab-content { display: none; }
    .tab-content.active { display: block; }

    /* CARDS */
    .section-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 28px;
        margin-bottom: 28px;
    }
    .section-card h2 {
        font-family: 'Syne', sans-serif;
        font-size: 18px;
        font-weight: 700;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 12px;
    }
    .icon-badge {
        width: 34px;
        height: 34px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
    }
    .placement-badge { background: rgba(247,156,66,.15); color: var(--orange); }
    .level-badge-icon { background: var(--accent-glow); color: var(--accent); }
    .green-badge { background: rgba(0,217,126,.15); color: var(--green); }

    /* FORM FIELDS (matching createCourse) */
    .field {
        margin-bottom: 20px;
    }
    .field label {
        display: block;
        font-size: 12px;
        font-weight: 600;
        color: var(--muted);
        margin-bottom: 8px;
        letter-spacing: 0.5px;
        text-transform: uppercase;
    }
    .field input, .field select, .field textarea {
        width: 100%;
        background: var(--surface2);
        border: 1.5px solid var(--border);
        border-radius: 12px;
        color: var(--text);
        padding: 12px 16px;
        font-family: 'DM Sans', sans-serif;
        font-size: 14px;
        outline: none;
        transition: border-color 0.2s;
    }
    .field input:focus, .field select:focus, .field textarea:focus {
        border-color: var(--accent);
    }
    .row-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    .row-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px; }

    /* QUESTIONS */
    .questions-container { display: flex; flex-direction: column; gap: 18px; margin-top: 8px; }
    .question-card {
        background: var(--surface2);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 22px;
        position: relative;
    }
    .q-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 16px;
    }
    .q-num { font-size: 11px; font-weight: 700; letter-spacing: 1px; color: var(--accent); }
    .q-type-tag {
        font-size: 10px;
        font-weight: 600;
        padding: 4px 12px;
        border-radius: 30px;
        background: var(--bg);
    }
    .tag-mc { background: var(--accent-glow); color: var(--accent); }
    .tag-tf { background: rgba(0,217,126,.15); color: var(--green); }
    .tag-ms { background: rgba(247,156,66,.15); color: var(--orange); }
    .tag-wr { background: rgba(255,107,107,.15); color: var(--red); }
    .del-q-btn {
        position: absolute;
        top: 18px;
        right: 18px;
        background: rgba(255,107,107,.12);
        border: none;
        border-radius: 8px;
        padding: 5px 12px;
        font-size: 11px;
        color: var(--red);
        cursor: pointer;
    }
    .q-input {
        width: 100%;
        background: var(--bg);
        border: 1.5px solid var(--border);
        border-radius: 12px;
        padding: 12px 14px;
        color: var(--text);
        font-size: 14px;
        margin-bottom: 18px;
        outline: none;
    }
    .options-area { display: flex; flex-direction: column; gap: 10px; margin-top: 6px; }
    .opt-row {
        display: flex;
        align-items: center;
        gap: 12px;
        background: var(--bg);
        padding: 8px 12px;
        border-radius: 10px;
    }
    .opt-row input[type="text"] {
        flex: 1;
        background: transparent;
        border: none;
        color: var(--text);
        padding: 8px 0;
        outline: none;
    }
    .correct-marker {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 12px;
        white-space: nowrap;
    }
    .add-opt-btn {
        background: transparent;
        border: 1.5px dashed var(--border);
        border-radius: 10px;
        padding: 10px;
        width: 100%;
        color: var(--muted);
        font-size: 12px;
        cursor: pointer;
        margin-top: 10px;
    }
    .tf-area {
        display: flex;
        gap: 12px;
        margin-bottom: 12px;
    }
    .tf-option {
        flex: 1;
        background: var(--bg);
        padding: 12px;
        border-radius: 10px;
        text-align: center;
        border: 1.5px solid var(--border);
    }
    .tf-correct-row {
        display: flex;
        gap: 12px;
        margin-top: 8px;
    }
    .tf-correct-btn {
        flex: 1;
        background: var(--bg);
        border: 1.5px solid var(--border);
        border-radius: 10px;
        padding: 10px;
        color: var(--muted);
        font-weight: 600;
        cursor: pointer;
    }
    .tf-correct-btn.selected-true { border-color: var(--green); color: var(--green); background: rgba(0,217,126,.1); }
    .tf-correct-btn.selected-false { border-color: var(--red); color: var(--red); background: rgba(255,107,107,.1); }
    .written-area input {
        width: 100%;
        background: var(--bg);
        border: 1.5px solid var(--border);
        border-radius: 12px;
        padding: 12px;
        color: var(--text);
    }
    .add-question-bar {
        border: 1.5px dashed var(--border);
        border-radius: 14px;
        padding: 18px;
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-top: 18px;
    }
    .add-q-btn {
        background: var(--surface2);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 8px 18px;
        font-size: 12px;
        font-weight: 500;
        color: var(--text);
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .save-btn {
        background: linear-gradient(135deg, var(--accent), #6366f1);
        border: none;
        padding: 14px 32px;
        border-radius: 40px;
        font-size: 15px;
        font-weight: 700;
        color: white;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        margin-top: 28px;
    }
    .quiz-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
        margin-bottom: 28px;
    }
    .quiz-item {
        background: var(--surface2);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 16px 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    .qi-left { display: flex; align-items: center; gap: 14px; }
    .qi-type-dot { width: 10px; height: 10px; border-radius: 50%; }
    .dot-placement { background: var(--orange); }
    .dot-beginner { background: var(--green); }
    .dot-intermediate { background: var(--accent); }
    .dot-advanced { background: var(--red); }
    .del-quiz-btn {
        background: rgba(255,107,107,.12);
        border: none;
        border-radius: 8px;
        padding: 6px 14px;
        color: var(--red);
        cursor: pointer;
    }
    .level-chip {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 30px;
        font-size: 11px;
        font-weight: 600;
    }
    .chip-beginner { background: rgba(0,217,126,.15); color: var(--green); }
    .chip-intermediate { background: var(--accent-glow); color: var(--accent); }
    .chip-advanced { background: rgba(255,107,107,.15); color: var(--red); }
    
    /* TABLE STYLES */
    .lessons-table {
        width: 100%;
        border-collapse: collapse;
    }
    .lessons-table th {
        text-align: left;
        padding: 14px 10px;
        font-size: 12px;
        font-weight: 600;
        color: var(--muted);
        border-bottom: 1px solid var(--border);
    }
    .lessons-table td {
        padding: 14px 10px;
        border-bottom: 1px solid var(--border);
        font-size: 14px;
    }

    .toast {
        position: fixed;
        bottom: 28px;
        right: 28px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 14px 22px;
        display: flex;
        align-items: center;
        gap: 10px;
        transform: translateY(80px);
        opacity: 0;
        transition: all 0.3s;
        z-index: 1000;
    }
    .toast.show { transform: translateY(0); opacity: 1; }
    .toast.success { border-color: var(--green); }
    .toast.error { border-color: var(--red); }
    
    .footer {
        margin-top: 48px;
        text-align: center;
        color: var(--muted);
        font-size: 12px;
        border-top: 1px solid var(--border);
        padding-top: 28px;
    }
    </style>
</head>
<body>
<div class="page-container">

    <!-- SIDEBAR (exactly same as createCourse) -->
    <div class="sidebar">
        <div class="logo">
            <img src="/img/logoBleu.png" class="logo-img" alt="Eduphin Logo">
            <span>Eduphin</span>
        </div>
        <div class="menu">
            <ul>
                <li><a href="/teacherDashboard/get"><i class="fas fa-home"></i> Dashboard</a></li>
                <li><a href="/courses/All"><i class="fas fa-book"></i> All Courses</a></li>
                <li class="active"><a href="#"><i class="fas fa-list"></i> Course Content</a></li>
                <li><a href="/profile/Profile-view"><i class="fas fa-user"></i> My Profile</a></li>
                <li><a href="/teacherDashboard/selectCourseForQuiz"><i class="fas fa-puzzle-piece"></i> Create Quiz</a></li>
                <li><a href="/App/studentAnalytics"><i class="fas fa-chart-line"></i> Student Analytics</a></li>
            </ul>
        </div>
        <a href="/home" class="logout">
            <i class="fas fa-sign-out-alt"></i> Sign out
        </a>
    </div>

    <div class="main">
        <div class="main-header">
            <h2><%= course.Title %> <span>| Content Studio</span></h2>
            <div class="breadcrumb">
                <a href="/teacherDashboard/get">Home</a> &rsaquo; <a href="/courses/All">Courses</a> &rsaquo; Manage Content
            </div>
        </div>

        <div class="tabs">
            <button class="tab-btn active" onclick="switchTab('lessons', this)"><i class="fas fa-play-circle"></i> Lessons</button>
            <button class="tab-btn" onclick="switchTab('placement', this)"><i class="fas fa-brain"></i> Placement Quiz</button>
            <button class="tab-btn" onclick="switchTab('levelquizzes', this)"><i class="fas fa-puzzle-piece"></i> Level Quizzes</button>
        </div>

        <!-- TAB: LESSONS -->
        <div class="tab-content active" id="tab-lessons">
            <div class="section-card">
                <h2><span class="icon-badge green-badge"><i class="fas fa-list"></i></span> Course Lessons</h2>
                <% if(lessons && lessons.length > 0) { %>
                <table class="lessons-table">
                    <thead>
                        <tr><th>#</th><th>Name</th><th>Type</th><th>Level</th><th>Duration</th></tr>
                    </thead>
                    <tbody>
                    <% lessons.forEach((lesson, i) => { %>
                        <tr>
                            <td><%= i+1 %></td>
                            <td><%= lesson.name %></td>
                            <td><i class="fas <%= lesson.type === 'video' ? 'fa-video' : 'fa-file-pdf' %>"></i> <%= lesson.type %></td>
                            <td><span class="level-chip chip-<%= lesson.level %>"><%= lesson.level %></span></td>
                            <td><%= lesson.duration %></td>
                        </tr>
                    <% }) %>
                    </tbody>
                </table>
                <% } else { %>
                <p style="color:var(--muted); text-align:center; padding:40px;">No lessons added yet.</p>
                <% } %>
            </div>
        </div>

        <!-- TAB: PLACEMENT QUIZ -->
        <div class="tab-content" id="tab-placement">
            <div class="section-card">
                <h2><span class="icon-badge placement-badge"><i class="fas fa-brain"></i></span> Placement / Level Test Quiz</h2>
                <p style="color:var(--muted); font-size:13px; margin-bottom:24px;">
                    Shown to students before accessing lessons. Score determines starting level.<br>
                    &lt; 40% Beginner | 40–69% Intermediate | ≥ 70% Advanced
                </p>
                <% if(placementQuiz) { %>
                <div class="quiz-list">
                    <div class="quiz-item">
                        <div class="qi-left"><div class="qi-type-dot dot-placement"></div><div><div class="qi-title"><%= placementQuiz.title %></div><div class="qi-meta"><%= placementQuiz.questions.length %> questions · Passing: <%= placementQuiz.passingScore || 70 %>%</div></div></div>
                        <button class="del-quiz-btn" onclick="deleteQuiz('<%= placementQuiz._id %>')"><i class="fas fa-trash"></i> Delete</button>
                    </div>
                </div>
                <% } else { %>
                <p style="color:var(--muted); margin-bottom:20px;">No placement quiz yet — create one below.</p>
                <% } %>
                <div class="row-2">
                    <div class="field"><label>Quiz Title</label><input type="text" id="pt-title" value="Level Assessment Quiz"></div>
                    <div class="field"><label>Passing Score (%)</label><input type="number" id="pt-passing" value="70" min="0" max="100"></div>
                </div>
                <div class="questions-container" id="pt-questions"></div>
                <div class="add-question-bar">
                    <button class="add-q-btn" onclick="addQuestion('pt', 'multiple-choice')"><i class="fas fa-circle-dot"></i> Multiple Choice</button>
                    <button class="add-q-btn" onclick="addQuestion('pt', 'true-false')"><i class="fas fa-toggle-on"></i> True/False</button>
                    <button class="add-q-btn" onclick="addQuestion('pt', 'multi-select')"><i class="fas fa-check-square"></i> Multi-Select</button>
                    <button class="add-q-btn" onclick="addQuestion('pt', 'written')"><i class="fas fa-pencil"></i> Written</button>
                </div>
                <button class="save-btn" onclick="saveQuiz('placement')"><i class="fas fa-floppy-disk"></i> Save Placement Quiz</button>
            </div>
        </div>

        <!-- TAB: LEVEL QUIZZES -->
        <div class="tab-content" id="tab-levelquizzes">
            <div class="section-card">
                <h2><span class="icon-badge level-badge-icon"><i class="fas fa-puzzle-piece"></i></span> Level Quizzes</h2>
                <p style="color:var(--muted); margin-bottom:24px;">One quiz per level. Unlocked after student completes all lessons for that level.</p>
                <% const allLevelQuizzes = [...(quizzesByLevel.beginner || []), ...(quizzesByLevel.intermediate || []), ...(quizzesByLevel.advanced || [])]; %>
                <% if(allLevelQuizzes.length > 0) { %>
                <div class="quiz-list">
                    <% allLevelQuizzes.forEach(q => { %>
                    <div class="quiz-item">
                        <div class="qi-left"><div class="qi-type-dot dot-<%= q.level %>"></div><div><div class="qi-title"><%= q.title %></div><div class="qi-meta"><%= q.level %> · <%= q.questions.length %> questions · Passing: <%= q.passingScore || 70 %>%</div></div></div>
                        <button class="del-quiz-btn" onclick="deleteQuiz('<%= q._id %>')"><i class="fas fa-trash"></i> Delete</button>
                    </div>
                    <% }) %>
                </div>
                <% } %>
                <div class="row-3">
                    <div class="field"><label>Quiz Title</label><input type="text" id="lq-title" placeholder="e.g., Beginner Final Quiz"></div>
                    <div class="field"><label>Level</label><select id="lq-level"><option value="beginner">Beginner</option><option value="intermediate">Intermediate</option><option value="advanced">Advanced</option></select></div>
                    <div class="field"><label>Passing Score (%)</label><input type="number" id="lq-passing" value="70" min="0" max="100"></div>
                </div>
                <div class="questions-container" id="lq-questions"></div>
                <div class="add-question-bar">
                    <button class="add-q-btn" onclick="addQuestion('lq', 'multiple-choice')"><i class="fas fa-circle-dot"></i> Multiple Choice</button>
                    <button class="add-q-btn" onclick="addQuestion('lq', 'true-false')"><i class="fas fa-toggle-on"></i> True/False</button>
                    <button class="add-q-btn" onclick="addQuestion('lq', 'multi-select')"><i class="fas fa-check-square"></i> Multi-Select</button>
                    <button class="add-q-btn" onclick="addQuestion('lq', 'written')"><i class="fas fa-pencil"></i> Written</button>
                </div>
                <button class="save-btn" onclick="saveQuiz('level')"><i class="fas fa-floppy-disk"></i> Save Level Quiz</button>
            </div>
        </div>
        <div class="footer">© 2026 Eduphin. All Rights Reserved.</div>
    </div>
</div>
<div class="toast" id="toast"></div>

<script>
const COURSE_SLUG = '<%= course.slug %>';
let ptCount = 0, lqCount = 0;

function switchTab(name, btn) {
    document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.getElementById('tab-' + name).classList.add('active');
    btn.classList.add('active');
}

function addQuestion(prefix, type) {
    const container = document.getElementById(`${prefix}-questions`);
    const idx = prefix === 'pt' ? ptCount++ : lqCount++;
    const meta = { 'multiple-choice':{tag:'MC',cls:'tag-mc',icon:'fa-circle-dot'}, 'true-false':{tag:'T/F',cls:'tag-tf',icon:'fa-toggle-on'}, 'multi-select':{tag:'SELECT ALL',cls:'tag-ms',icon:'fa-check-square'}, 'written':{tag:'WRITTEN',cls:'tag-wr',icon:'fa-pencil'} }[type];
    const card = document.createElement('div'); card.className = 'question-card'; card.id = `${prefix}-q-${idx}`; card.dataset.type = type; card.dataset.idx = idx;
    card.innerHTML = `<div class="q-header"><span class="q-num">Question ${idx+1}</span><span class="q-type-tag ${meta.cls}"><i class="fas ${meta.icon}"></i> ${meta.tag}</span></div><button class="del-q-btn" onclick="this.closest('.question-card').remove()"><i class="fas fa-times"></i> Remove</button><input type="text" class="q-input" placeholder="Enter your question…" data-role="question">${buildBody(prefix, idx, type)}`;
    container.appendChild(card);
}
function buildBody(prefix, idx, type) {
    if(type==='true-false') return `<div class="tf-area"><div class="tf-option"><i class="fas fa-check"></i> True</div><div class="tf-option"><i class="fas fa-times"></i> False</div></div><div class="tf-correct-row"><button type="button" class="tf-correct-btn" data-value="0" onclick="selectTF(this,'${prefix}',${idx})">✅ True is correct</button><button type="button" class="tf-correct-btn" data-value="1" onclick="selectTF(this,'${prefix}',${idx})">❌ False is correct</button></div><input type="hidden" data-role="correctAnswer">`;
    if(type==='multiple-choice') return `<div class="options-area" data-optcount="2">${optRow(0,'radio')}${optRow(1,'radio')}</div><button class="add-opt-btn" onclick="addOption(this,'radio')"><i class="fas fa-plus"></i> Add Option</button>`;
    if(type==='multi-select') return `<p style="font-size:12px;color:var(--orange);margin-bottom:8px"><i class="fas fa-info-circle"></i> Check ALL correct answers</p><div class="options-area" data-optcount="2">${optRow(0,'checkbox')}${optRow(1,'checkbox')}</div><button class="add-opt-btn" onclick="addOption(this,'checkbox')"><i class="fas fa-plus"></i> Add Option</button>`;
    if(type==='written') return `<div class="written-area"><label><i class="fas fa-pencil"></i> Expected Answer</label><input type="text" data-role="correctAnswerText" placeholder="Type expected answer..."></div>`;
    return '';
}
function optRow(optIdx, inputType) { return `<div class="opt-row" data-opt-idx="${optIdx}"><input type="text" placeholder="Option ${String.fromCharCode(65+optIdx)}…"><label class="correct-marker"><input type="${inputType}"> Correct</label></div>`; }
function addOption(btn, inputType) { const area = btn.previousElementSibling; let cnt = parseInt(area.dataset.optcount); area.dataset.optcount = ++cnt; area.insertAdjacentHTML('beforeend', optRow(cnt-1, inputType)); }
function selectTF(btn, prefix, idx) { const card = document.getElementById(`${prefix}-q-${idx}`); card.querySelectorAll('.tf-correct-btn').forEach(b=>b.className='tf-correct-btn'); btn.classList.add(btn.dataset.value==='0'?'selected-true':'selected-false'); card.querySelector('[data-role="correctAnswer"]').value=btn.dataset.value; }
function collectQuestions(prefix) { return [...document.querySelectorAll(`#${prefix}-questions .question-card`)].map(card=>{ const type=card.dataset.type, qText=card.querySelector('[data-role="question"]')?.value?.trim(); if(!qText) return null; const q={question:qText,questionType:type}; if(type==='true-false'){ q.options=['True','False']; q.correctAnswer=card.querySelector('[data-role="correctAnswer"]')?.value?parseInt(card.querySelector('[data-role="correctAnswer"]').value):null; } if(type==='multiple-choice'){ q.options=[]; q.correctAnswer=null; [...card.querySelectorAll('.opt-row')].forEach(row=>{ let txt=row.querySelector('input[type="text"]')?.value?.trim(); if(txt){ q.options.push(txt); if(row.querySelector('input[type="radio"]')?.checked) q.correctAnswer=q.options.length-1; } }); } if(type==='multi-select'){ q.options=[]; q.correctAnswers=[]; [...card.querySelectorAll('.opt-row')].forEach(row=>{ let txt=row.querySelector('input[type="text"]')?.value?.trim(); if(txt){ let idx=q.options.length; q.options.push(txt); if(row.querySelector('input[type="checkbox"]')?.checked) q.correctAnswers.push(idx); } }); } if(type==='written'){ q.correctAnswerText=card.querySelector('[data-role="correctAnswerText"]')?.value?.trim()||''; } return q; }).filter(Boolean); }
async function saveQuiz(quizType) { const isPlacement=quizType==='placement', prefix=isPlacement?'pt':'lq'; const title=document.getElementById(`${prefix}-title`)?.value?.trim(); const passing=parseInt(document.getElementById(`${prefix}-passing`)?.value)||70; const level=isPlacement?null:document.getElementById('lq-level')?.value; if(!title){ showToast('Enter a title','error'); return; } const questions=collectQuestions(prefix); if(questions.length===0){ showToast('Add at least one question','error'); return; } const payload={title,quizType:isPlacement?'placement':'level',passingScore:passing,questions}; if(!isPlacement) payload.level=level; try{ const res=await fetch(`/courses/content/${COURSE_SLUG}/quiz/save`,{method:'POST',headers:{'Content-Type':'application/json'},credentials:'include',body:JSON.stringify(payload)}); const data=await res.json(); if(data.success){ showToast('✓ Quiz saved!','success'); setTimeout(()=>location.reload(),1200); } else showToast(data.message||'Error','error'); } catch(err){ showToast('Network error','error'); } }
async function deleteQuiz(quizId){ if(!confirm('Delete this quiz?')) return; try{ const res=await fetch(`/courses/content/${COURSE_SLUG}/quiz/${quizId}`,{method:'DELETE',credentials:'include'}); const data=await res.json(); if(data.success){ showToast('Quiz deleted','success'); setTimeout(()=>location.reload(),900); } else showToast('Error','error'); } catch(err){ showToast('Error','error'); } }
function showToast(msg,type){ const t=document.getElementById('toast'); t.textContent=msg; t.className=`toast ${type} show`; setTimeout(()=>t.classList.remove('show'),3000); }
</script>
</body>
</html>