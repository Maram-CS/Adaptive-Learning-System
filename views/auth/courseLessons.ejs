<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Eduphin | Course Content Manager</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
    /* ─── COLOR VARIABLES (same as createCourse) ─── */
    :root {
      --blue-light:  #deeaf9;
      --blue-main:   #2b7de9;
      --blue-dark:   #053672;
      --orange:      #f4a640;
      --navy:        #0c1e36;
      --text-dark:   #1f2d3d;
      --text-muted:  #555;
      --bg-light:    #f8fbff;
      --success:     #2ecc71;
      --warning:     #f39c12;
      --danger:      #e74c3c;
      --gray-light:  #e9ecef;
      --white:       #ffffff;
      --shadow-sm:   0 2px 10px rgba(0,0,0,0.05);
      --shadow-md:   0 4px 12px rgba(0,0,0,0.08);
      --shadow-lg:   0 8px 20px rgba(0,0,0,0.12);
    }

    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }

    body { background: var(--bg-light); color: var(--text-dark); line-height: 1.6; }

    .page-container { display: flex; min-height: 100vh; }

    /* ─── SIDEBAR ─── */
    .sidebar {
      width: 260px; background: var(--navy); color: white;
      display: flex; flex-direction: column; padding: 30px 20px; gap: 30px;
      position: fixed; top: 0; left: 0; height: 100vh; z-index: 100;
    }
    .sidebar .logo {
      display: flex; align-items: center; gap: 12px;
      font-weight: 700; font-size: 20px; color: white;
    }
    .sidebar .logo .logo-img {
      width: 40px; height: 40px; border-radius: 10px;
      background: var(--blue-main); object-fit: cover;
    }
    .sidebar .menu ul { list-style: none; display: flex; flex-direction: column; gap: 8px; }
    .sidebar .menu ul li {
      padding: 12px 16px; border-radius: 12px; cursor: pointer;
      font-weight: 500; color: rgba(255,255,255,0.75);
      transition: all 0.3s ease; position: relative; overflow: hidden;
    }
    .sidebar .menu ul li::before {
      content: ''; position: absolute; top: 0; left: -100%; width: 100%; height: 100%;
      background: linear-gradient(90deg, transparent, rgba(43,125,233,0.3), transparent);
      transition: left 0.4s ease;
    }
    .sidebar .menu ul li:hover::before { left: 100%; }
    .sidebar .menu ul li::after {
      content: ''; position: absolute; left: 0; top: 50%;
      transform: translateY(-50%) scaleY(0); width: 3px; height: 60%;
      background: var(--orange); border-radius: 3px; transition: transform 0.3s ease;
    }
    .sidebar .menu ul li:hover::after,
    .sidebar .menu ul li.active::after { transform: translateY(-50%) scaleY(1); }
    .sidebar .menu ul li:hover { background: rgba(43,125,233,0.2); color: white; transform: translateX(5px); }
    .sidebar .menu ul li.active { background: var(--blue-main); color: white; }
    .sidebar .menu ul li a {
      text-decoration: none; color: inherit; display: flex; align-items: center;
      gap: 12px; position: relative; z-index: 1;
    }
    .sidebar .menu ul li a i { width: 18px; text-align: center; }
    .sidebar a { text-decoration: none; }
    .sidebar .logout {
      margin-top: 0; background: var(--orange); border: none;
      padding: 12px 20px; border-radius: 30px; color: var(--navy);
      font-weight: 700; cursor: pointer; font-size: 15px; transition: all 0.3s;
      width: 100%; position: relative; overflow: hidden; display: block; text-align: center;
    }
    .sidebar .logout::before {
      content: ''; position: absolute; top: 0; left: -100%; width: 100%; height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
      transition: left 0.4s;
    }
    .sidebar .logout:hover::before { left: 100%; }
    .sidebar .logout:hover {
      background: var(--blue-main); color: white;
      transform: translateY(-2px); box-shadow: 0 4px 12px rgba(43,125,233,0.4);
    }

    /* ─── MAIN ─── */
    .main { margin-left: 260px; flex: 1; padding: 30px 40px; }

    /* ─── HEADER ─── */
    .main-header {
      display: flex; justify-content: space-between; align-items: center;
      background: var(--blue-light); padding: 18px 25px; border-radius: 16px;
      margin-bottom: 10px; box-shadow: var(--shadow-sm);
    }
    .main-header h2 { font-size: 24px; color: var(--blue-dark); }
    .main-header h2 span { color: var(--orange); }

    .breadcrumb { font-size: 14px; margin-bottom: 24px; color: var(--text-muted); }
    .breadcrumb a { color: var(--blue-main); text-decoration: none; }
    .breadcrumb a:hover { text-decoration: underline; }

    .orange { color: var(--orange); }
    .blue   { color: var(--blue-dark); }

    /* ─── TABS ─── */
    .tabs { display: flex; gap: 10px; margin-bottom: 24px; flex-wrap: wrap; }
    .tab-btn {
      display: flex; align-items: center; gap: 8px;
      padding: 10px 24px; border-radius: 30px;
      border: 2px solid var(--gray-light); background: var(--white);
      color: var(--text-muted); font-size: 14px; font-weight: 600;
      cursor: pointer; transition: all 0.25s ease;
    }
    .tab-btn:hover:not(.active) {
      border-color: var(--blue-main); color: var(--blue-main);
      transform: translateY(-2px); box-shadow: var(--shadow-sm);
    }
    .tab-btn.active {
      background: var(--blue-main); border-color: var(--blue-main);
      color: white; box-shadow: 0 4px 12px rgba(43,125,233,0.35);
    }
    .tab-content { display: none; }
    .tab-content.active { display: block; }

    /* ─── FORM SECTION ─── */
    .form-section {
      background: var(--white); border-radius: 20px;
      padding: 24px 28px; margin-bottom: 28px;
      box-shadow: var(--shadow-sm); transition: box-shadow 0.3s ease;
    }
    .form-section:hover { box-shadow: var(--shadow-md); }
    .form-section-title {
      font-size: 20px; font-weight: 700; color: var(--blue-dark);
      margin-bottom: 20px; padding-bottom: 12px;
      border-bottom: 2px solid var(--blue-light);
      display: flex; align-items: center; gap: 12px; flex-wrap: wrap;
    }
    .form-section-title i { color: var(--orange); font-size: 22px; }
    .section-desc { font-size: 13px; color: var(--text-muted); margin-bottom: 20px; line-height: 1.6; }

    /* ─── FIELDS ─── */
    .field { display: flex; flex-direction: column; gap: 8px; margin-bottom: 18px; }
    .field label { font-weight: 600; color: var(--text-dark); font-size: 14px; }
    .field input, .field select, .field textarea {
      padding: 12px 16px; border: 1.5px solid var(--gray-light);
      border-radius: 12px; font-size: 14px; transition: all 0.3s ease;
      background: var(--white); outline: none;
    }
    .field input:focus, .field select:focus, .field textarea:focus {
      border-color: var(--blue-main); box-shadow: 0 0 0 3px rgba(43,125,233,0.1);
    }
    .form-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    .form-grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px; }

    /* ─── BUTTONS ─── */
    .btn-create {
      padding: 12px 28px; border-radius: 40px; font-weight: 700; font-size: 14px;
      cursor: pointer; transition: all 0.3s ease; border: none;
      display: inline-flex; align-items: center; gap: 8px;
      background: var(--blue-main); color: white;
      box-shadow: 0 2px 8px rgba(43,125,233,0.3);
    }
    .btn-create:hover {
      background: var(--blue-dark); transform: translateY(-2px);
      box-shadow: 0 6px 14px rgba(43,125,233,0.4);
    }
    .btn-danger {
      padding: 8px 18px; border-radius: 30px; font-weight: 600; font-size: 13px;
      cursor: pointer; transition: all 0.3s; border: none;
      display: inline-flex; align-items: center; gap: 6px;
      background: #fde8e8; color: var(--danger);
    }
    .btn-danger:hover { background: var(--danger); color: white; }

    /* ─── LESSONS TABLE ─── */
    .lessons-table { width: 100%; border-collapse: collapse; }
    .lessons-table th {
      text-align: left; padding: 12px 14px; font-size: 12px;
      font-weight: 700; color: var(--text-muted); letter-spacing: 0.5px;
      text-transform: uppercase; border-bottom: 2px solid var(--blue-light);
    }
    .lessons-table td {
      padding: 14px; border-bottom: 1px solid var(--gray-light);
      font-size: 14px; vertical-align: middle;
    }
    .lessons-table tr:last-child td { border-bottom: none; }
    .lessons-table tr:hover td { background: var(--bg-light); }
    .num-cell { width: 40px; color: var(--text-muted); font-weight: 600; }
    .type-icon { display: inline-flex; align-items: center; gap: 6px; }
    .type-icon i { color: var(--blue-main); }

    /* ─── LEVEL CHIPS ─── */
    .level-chip {
      display: inline-block; padding: 4px 14px;
      border-radius: 30px; font-size: 12px; font-weight: 600;
    }
    .chip-beginner     { background: #d4f5e9; color: #1a7a4a; }
    .chip-intermediate { background: var(--blue-light); color: var(--blue-dark); }
    .chip-advanced     { background: #fde8e8; color: var(--danger); }

    /* ─── QUIZ LIST ─── */
    .quiz-list { display: flex; flex-direction: column; gap: 12px; margin-bottom: 24px; }
    .quiz-item {
      background: var(--bg-light); border: 1.5px solid var(--gray-light);
      border-radius: 14px; padding: 16px 20px;
      display: flex; align-items: center; justify-content: space-between;
      transition: all 0.2s;
    }
    .quiz-item:hover { border-color: var(--blue-main); box-shadow: var(--shadow-sm); }
    .qi-left { display: flex; align-items: center; gap: 14px; }
    .qi-type-dot { width: 12px; height: 12px; border-radius: 50%; flex-shrink: 0; }
    .dot-placement    { background: var(--orange); }
    .dot-beginner     { background: var(--success); }
    .dot-intermediate { background: var(--blue-main); }
    .dot-advanced     { background: var(--danger); }
    .qi-title { font-weight: 600; font-size: 15px; color: var(--text-dark); }
    .qi-meta  { font-size: 13px; color: var(--text-muted); margin-top: 2px; }

    /* ─── QUESTIONS ─── */
    .questions-container { display: flex; flex-direction: column; gap: 16px; margin-top: 8px; }
    .question-card {
      background: var(--bg-light); border: 1.5px solid var(--gray-light);
      border-radius: 16px; padding: 20px 22px; position: relative;
      transition: border-color 0.2s;
    }
    .question-card:hover { border-color: var(--blue-main); }
    .q-header { display: flex; align-items: center; gap: 10px; margin-bottom: 14px; }
    .q-num { font-size: 11px; font-weight: 700; letter-spacing: 1px; color: var(--blue-main); text-transform: uppercase; }
    .q-type-tag {
      font-size: 11px; font-weight: 700; padding: 3px 12px;
      border-radius: 30px; text-transform: uppercase; letter-spacing: 0.5px;
    }
    .tag-mc { background: var(--blue-light); color: var(--blue-dark); }
    .tag-tf { background: #d4f5e9; color: #1a7a4a; }
    .tag-ms { background: #fff3e0; color: #b06000; }
    .tag-wr { background: #fde8e8; color: var(--danger); }
    .del-q-btn {
      position: absolute; top: 16px; right: 16px; background: #fde8e8;
      border: none; border-radius: 8px; padding: 5px 12px;
      font-size: 11px; font-weight: 600; color: var(--danger); cursor: pointer; transition: all 0.2s;
    }
    .del-q-btn:hover { background: var(--danger); color: white; }
    .q-input {
      width: 100%; background: var(--white); border: 1.5px solid var(--gray-light);
      border-radius: 12px; padding: 12px 14px; color: var(--text-dark);
      font-size: 14px; margin-bottom: 14px; outline: none; transition: border-color 0.2s;
    }
    .q-input:focus { border-color: var(--blue-main); }
    .options-area { display: flex; flex-direction: column; gap: 8px; margin-top: 4px; }
    .opt-row {
      display: flex; align-items: center; gap: 12px;
      background: var(--white); padding: 8px 14px;
      border-radius: 10px; border: 1.5px solid var(--gray-light);
    }
    .opt-row input[type="text"] {
      flex: 1; background: transparent; border: none;
      color: var(--text-dark); padding: 6px 0; outline: none; font-size: 14px;
    }
    .correct-marker {
      display: flex; align-items: center; gap: 6px;
      font-size: 12px; font-weight: 600; color: var(--text-muted); white-space: nowrap;
    }
    .add-opt-btn {
      background: transparent; border: 1.5px dashed var(--gray-light);
      border-radius: 10px; padding: 10px; width: 100%; color: var(--text-muted);
      font-size: 13px; cursor: pointer; margin-top: 8px; transition: all 0.2s;
    }
    .add-opt-btn:hover { border-color: var(--blue-main); color: var(--blue-main); }
    .tf-area { display: flex; gap: 12px; margin-bottom: 10px; }
    .tf-option {
      flex: 1; background: var(--white); padding: 12px; border-radius: 10px;
      text-align: center; border: 1.5px solid var(--gray-light);
      font-weight: 600; color: var(--text-muted);
    }
    .tf-correct-row { display: flex; gap: 12px; margin-top: 6px; }
    .tf-correct-btn {
      flex: 1; background: var(--white); border: 1.5px solid var(--gray-light);
      border-radius: 10px; padding: 10px; color: var(--text-muted);
      font-weight: 600; cursor: pointer; transition: all 0.2s;
    }
    .tf-correct-btn.selected-true  { border-color: var(--success); color: var(--success); background: #d4f5e9; }
    .tf-correct-btn.selected-false { border-color: var(--danger);  color: var(--danger);  background: #fde8e8; }
    .written-area input {
      width: 100%; background: var(--white); border: 1.5px solid var(--gray-light);
      border-radius: 12px; padding: 12px; color: var(--text-dark);
      outline: none; font-size: 14px; transition: border-color 0.2s;
    }
    .written-area input:focus { border-color: var(--blue-main); }
    .add-question-bar {
      border: 1.5px dashed var(--gray-light); border-radius: 14px;
      padding: 16px; display: flex; gap: 10px; flex-wrap: wrap; margin-top: 16px;
    }
    .add-q-btn {
      background: var(--white); border: 1.5px solid var(--gray-light);
      border-radius: 30px; padding: 8px 18px; font-size: 13px; font-weight: 600;
      color: var(--text-dark); cursor: pointer;
      display: inline-flex; align-items: center; gap: 8px; transition: all 0.2s;
    }
    .add-q-btn:hover {
      border-color: var(--blue-main); color: var(--blue-main);
      transform: translateY(-1px); box-shadow: var(--shadow-sm);
    }
    .add-q-btn i { color: var(--orange); }

    /* ─── EMPTY STATE ─── */
    .empty-state { text-align: center; padding: 48px 20px; color: var(--text-muted); }
    .empty-state i { font-size: 48px; color: var(--gray-light); margin-bottom: 16px; display: block; }

    /* ─── TOAST ─── */
    .toast {
      position: fixed; bottom: 24px; right: 24px; z-index: 999;
      padding: 14px 22px; border-radius: 12px;
      display: flex; align-items: center; gap: 10px;
      font-weight: 600; font-size: 14px;
      transform: translateY(80px); opacity: 0; transition: all 0.3s;
      pointer-events: none; box-shadow: var(--shadow-lg);
    }
    .toast.show { transform: translateY(0); opacity: 1; }
    .toast.success { background: #d4f5e9; color: #1a7a4a; border: 1.5px solid #a8e6cf; }
    .toast.error   { background: #fde8e8; color: var(--danger); border: 1.5px solid #f5c6c6; }

    /* ─── FOOTER ─── */
    .footer {
      background: var(--navy); color: white; text-align: center;
      padding: 20px; margin-top: 40px; border-radius: 16px; font-size: 14px;
    }

    /* ─── RESPONSIVE ─── */
    @media (max-width: 768px) {
      .sidebar { width: 100%; height: auto; position: relative; flex-direction: row; flex-wrap: wrap; padding: 15px; }
      .main { margin-left: 0; padding: 20px; }
      .form-grid-2, .form-grid-3 { grid-template-columns: 1fr; }
      .main-header { flex-direction: column; gap: 12px; }
    }
    </style>
</head>
<body>
<div class="page-container">

    <!-- SIDEBAR -->
    <div class="sidebar">
        <div class="logo">
            <img src="/img/logoBleu.png" class="logo-img" alt="Eduphin Logo">
            <span>Eduphin</span>
        </div>
        <div class="menu">
            <ul>
                <li class="active">Course Content</li>
                <li><a href="/teacherDashboard/get">Home</a></li>
                <li><a href="/profile/Profile-view">My Profile</a></li>
                <li><a href="/App/studentAnalytics">Student Analytics</a></li>
            </ul>
        </div>
        <br><br><br><br><br>
        <a href="/home">
            <button class="logout">Sign out</button>
        </a>
    </div>

    <!-- MAIN -->
    <div class="main">

        <div class="main-header">
            <h2><%= course.Title %> <span>| Content Studio</span></h2>
        </div>

        <div class="breadcrumb">
            <a href="/teacherDashboard/get">Home</a> &rsaquo;
            <a href="/courses/All">Courses</a> &rsaquo;
            Manage Content
        </div>

        <!-- TABS -->
        <div class="tabs">
            <button class="tab-btn active" onclick="switchTab('lessons', this)">
                <i class="fas fa-play-circle"></i> Lessons
            </button>
            <button class="tab-btn" onclick="switchTab('placement', this)">
                <i class="fas fa-brain"></i> Placement Quiz
            </button>
            <button class="tab-btn" onclick="switchTab('levelquizzes', this)">
                <i class="fas fa-puzzle-piece"></i> Level Quizzes
            </button>
        </div>

        <!-- ══════ TAB: LESSONS ══════ -->
        <div class="tab-content active" id="tab-lessons">
            <div class="form-section">
                <div class="form-section-title">
                    <i class="fas fa-list-ul"></i> Course Lessons
                </div>
                <% if(lessons && lessons.length > 0) { %>
                <table class="lessons-table">
                    <thead>
                        <tr>
                            <th class="num-cell">#</th>
                            <th>Name</th>
                            <th>Type</th>
                            <th>Level</th>
                            <th>Duration</th>
                        </tr>
                    </thead>
                    <tbody>
                    <% lessons.forEach((lesson, i) => { %>
                        <tr>
                            <td class="num-cell"><%= i+1 %></td>
                            <td><strong><%= lesson.name %></strong></td>
                            <td>
                                <span class="type-icon">
                                    <i class="fas <%= lesson.type === 'video' ? 'fa-video' : 'fa-file-pdf' %>"></i>
                                    <%= lesson.type %>
                                </span>
                            </td>
                            <td><span class="level-chip chip-<%= lesson.level %>"><%= lesson.level %></span></td>
                            <td><%= lesson.duration %></td>
                        </tr>
                    <% }) %>
                    </tbody>
                </table>
                <% } else { %>
                <div class="empty-state">
                    <i class="fas fa-film"></i>
                    <p>No lessons added yet.</p>
                </div>
                <% } %>
            </div>
        </div>

        <!-- ══════ TAB: PLACEMENT QUIZ ══════ -->
        <div class="tab-content" id="tab-placement">
            <div class="form-section">
                <div class="form-section-title">
                    <i class="fas fa-brain"></i> Placement / Level Test Quiz
                </div>
                <p class="section-desc">
                    Shown to students before accessing lessons. Score determines starting level.<br>
                    &lt; 40% → Beginner &nbsp;|&nbsp; 40–69% → Intermediate &nbsp;|&nbsp; ≥ 70% → Advanced
                </p>

                <% if(placementQuiz) { %>
                <div class="quiz-list">
                    <div class="quiz-item">
                        <div class="qi-left">
                            <div class="qi-type-dot dot-placement"></div>
                            <div>
                                <div class="qi-title"><%= placementQuiz.title %></div>
                                <div class="qi-meta">
                                    <%= placementQuiz.questions.length %> questions &nbsp;·&nbsp;
                                    Passing: <%= placementQuiz.passingScore || 70 %>%
                                </div>
                            </div>
                        </div>
                        <button class="btn-danger" onclick="deleteQuiz('<%= placementQuiz._id %>')">
                            <i class="fas fa-trash"></i> Delete
                        </button>
                    </div>
                </div>
                <% } else { %>
                <p style="color:var(--text-muted); margin-bottom:20px; font-size:14px;">
                    No placement quiz yet — create one below.
                </p>
                <% } %>

                <div class="form-grid-2">
                    <div class="field">
                        <label>Quiz Title</label>
                        <input type="text" id="pt-title" value="Level Assessment Quiz">
                    </div>
                    <div class="field">
                        <label>Passing Score (%)</label>
                        <input type="number" id="pt-passing" value="70" min="0" max="100">
                    </div>
                </div>

                <div class="questions-container" id="pt-questions"></div>

                <div class="add-question-bar">
                    <button class="add-q-btn" onclick="addQuestion('pt','multiple-choice')"><i class="fas fa-circle-dot"></i> Multiple Choice</button>
                    <button class="add-q-btn" onclick="addQuestion('pt','true-false')"><i class="fas fa-toggle-on"></i> True / False</button>
                    <button class="add-q-btn" onclick="addQuestion('pt','multi-select')"><i class="fas fa-check-square"></i> Multi-Select</button>
                    <button class="add-q-btn" onclick="addQuestion('pt','written')"><i class="fas fa-pencil"></i> Written</button>
                </div>

                <br>
                <button class="btn-create" onclick="saveQuiz('placement')">
                    <i class="fas fa-floppy-disk"></i> Save Placement Quiz
                </button>
            </div>
        </div>

        <!-- ══════ TAB: LEVEL QUIZZES ══════ -->
        <div class="tab-content" id="tab-levelquizzes">
            <div class="form-section">
                <div class="form-section-title">
                    <i class="fas fa-puzzle-piece"></i> Level Quizzes
                </div>
                <p class="section-desc">
                    One quiz per level. Unlocked after a student completes all lessons for that level.
                </p>

                <% const allLevelQuizzes = [...(quizzesByLevel.beginner || []), ...(quizzesByLevel.intermediate || []), ...(quizzesByLevel.advanced || [])]; %>
                <% if(allLevelQuizzes.length > 0) { %>
                <div class="quiz-list">
                    <% allLevelQuizzes.forEach(q => { %>
                    <div class="quiz-item">
                        <div class="qi-left">
                            <div class="qi-type-dot dot-<%= q.level %>"></div>
                            <div>
                                <div class="qi-title"><%= q.title %></div>
                                <div class="qi-meta">
                                    <span class="level-chip chip-<%= q.level %>"><%= q.level %></span>
                                    &nbsp;· <%= q.questions.length %> questions
                                    &nbsp;· Passing: <%= q.passingScore || 70 %>%
                                </div>
                            </div>
                        </div>
                        <button class="btn-danger" onclick="deleteQuiz('<%= q._id %>')">
                            <i class="fas fa-trash"></i> Delete
                        </button>
                    </div>
                    <% }) %>
                </div>
                <% } %>

                <div class="form-grid-3">
                    <div class="field">
                        <label>Quiz Title</label>
                        <input type="text" id="lq-title" placeholder="e.g., Beginner Final Quiz">
                    </div>
                    <div class="field">
                        <label>Level</label>
                        <select id="lq-level">
                            <option value="beginner">Beginner</option>
                            <option value="intermediate">Intermediate</option>
                            <option value="advanced">Advanced</option>
                        </select>
                    </div>
                    <div class="field">
                        <label>Passing Score (%)</label>
                        <input type="number" id="lq-passing" value="70" min="0" max="100">
                    </div>
                </div>

                <div class="questions-container" id="lq-questions"></div>

                <div class="add-question-bar">
                    <button class="add-q-btn" onclick="addQuestion('lq','multiple-choice')"><i class="fas fa-circle-dot"></i> Multiple Choice</button>
                    <button class="add-q-btn" onclick="addQuestion('lq','true-false')"><i class="fas fa-toggle-on"></i> True / False</button>
                    <button class="add-q-btn" onclick="addQuestion('lq','multi-select')"><i class="fas fa-check-square"></i> Multi-Select</button>
                    <button class="add-q-btn" onclick="addQuestion('lq','written')"><i class="fas fa-pencil"></i> Written</button>
                </div>

                <br>
                <button class="btn-create" onclick="saveQuiz('level')">
                    <i class="fas fa-floppy-disk"></i> Save Level Quiz
                </button>
            </div>
        </div>

        <div class="footer">© 2026 Eduphin. All Rights Reserved.</div>
    </div>
</div>

<div class="toast" id="toast"></div>

<script>
const COURSE_SLUG = '<%= course.slug %>';
let ptCount = 0, lqCount = 0;

function switchTab(name, btn) {
    document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.getElementById('tab-' + name).classList.add('active');
    btn.classList.add('active');
}

function addQuestion(prefix, type) {
    const container = document.getElementById(`${prefix}-questions`);
    const idx = prefix === 'pt' ? ptCount++ : lqCount++;
    const meta = {
        'multiple-choice': { tag: 'Multiple Choice', cls: 'tag-mc', icon: 'fa-circle-dot'  },
        'true-false':      { tag: 'True / False',    cls: 'tag-tf', icon: 'fa-toggle-on'   },
        'multi-select':    { tag: 'Multi-Select',    cls: 'tag-ms', icon: 'fa-check-square' },
        'written':         { tag: 'Written',         cls: 'tag-wr', icon: 'fa-pencil'       }
    }[type];
    const card = document.createElement('div');
    card.className = 'question-card';
    card.id = `${prefix}-q-${idx}`;
    card.dataset.type = type;
    card.dataset.idx  = idx;
    card.innerHTML = `
        <div class="q-header">
            <span class="q-num">Question ${idx + 1}</span>
            <span class="q-type-tag ${meta.cls}"><i class="fas ${meta.icon}"></i> ${meta.tag}</span>
        </div>
        <button class="del-q-btn" onclick="this.closest('.question-card').remove()">
            <i class="fas fa-times"></i> Remove
        </button>
        <input type="text" class="q-input" placeholder="Enter your question…" data-role="question">
        ${buildBody(prefix, idx, type)}`;
    container.appendChild(card);
}

function buildBody(prefix, idx, type) {
    if (type === 'true-false') return `
        <div class="tf-area">
            <div class="tf-option"><i class="fas fa-check" style="color:var(--success)"></i> True</div>
            <div class="tf-option"><i class="fas fa-times" style="color:var(--danger)"></i> False</div>
        </div>
        <div class="tf-correct-row">
            <button type="button" class="tf-correct-btn" data-value="0" onclick="selectTF(this,'${prefix}',${idx})">✅ True is correct</button>
            <button type="button" class="tf-correct-btn" data-value="1" onclick="selectTF(this,'${prefix}',${idx})">❌ False is correct</button>
        </div>
        <input type="hidden" data-role="correctAnswer">`;
    if (type === 'multiple-choice') return `
        <div class="options-area" data-optcount="2">${optRow(0,'radio')}${optRow(1,'radio')}</div>
        <button class="add-opt-btn" onclick="addOption(this,'radio')"><i class="fas fa-plus"></i> Add Option</button>`;
    if (type === 'multi-select') return `
        <p style="font-size:13px;color:var(--warning);margin-bottom:8px;font-weight:600;">
            <i class="fas fa-info-circle"></i> Check ALL correct answers
        </p>
        <div class="options-area" data-optcount="2">${optRow(0,'checkbox')}${optRow(1,'checkbox')}</div>
        <button class="add-opt-btn" onclick="addOption(this,'checkbox')"><i class="fas fa-plus"></i> Add Option</button>`;
    if (type === 'written') return `
        <div class="written-area">
            <label style="font-size:13px;font-weight:600;color:var(--text-muted);display:block;margin-bottom:6px;">
                <i class="fas fa-pencil"></i> Expected Answer
            </label>
            <input type="text" data-role="correctAnswerText" placeholder="Type expected answer...">
        </div>`;
    return '';
}

function optRow(optIdx, inputType) {
    return `<div class="opt-row" data-opt-idx="${optIdx}">
        <input type="text" placeholder="Option ${String.fromCharCode(65 + optIdx)}…">
        <label class="correct-marker"><input type="${inputType}"> Correct</label>
    </div>`;
}
function addOption(btn, inputType) {
    const area = btn.previousElementSibling;
    let cnt = parseInt(area.dataset.optcount);
    area.dataset.optcount = ++cnt;
    area.insertAdjacentHTML('beforeend', optRow(cnt - 1, inputType));
}
function selectTF(btn, prefix, idx) {
    const card = document.getElementById(`${prefix}-q-${idx}`);
    card.querySelectorAll('.tf-correct-btn').forEach(b => b.className = 'tf-correct-btn');
    btn.classList.add(btn.dataset.value === '0' ? 'selected-true' : 'selected-false');
    card.querySelector('[data-role="correctAnswer"]').value = btn.dataset.value;
}
function collectQuestions(prefix) {
    return [...document.querySelectorAll(`#${prefix}-questions .question-card`)].map(card => {
        const type = card.dataset.type;
        const qText = card.querySelector('[data-role="question"]')?.value?.trim();
        if (!qText) return null;
        const q = { question: qText, questionType: type };
        if (type === 'true-false') {
            q.options = ['True','False'];
            const raw = card.querySelector('[data-role="correctAnswer"]')?.value;
            q.correctAnswer = (raw !== '' && raw != null) ? parseInt(raw) : null;
        }
        if (type === 'multiple-choice') {
            q.options = []; q.correctAnswer = null;
            card.querySelectorAll('.opt-row').forEach(row => {
                const txt = row.querySelector('input[type="text"]')?.value?.trim();
                if (txt) { q.options.push(txt); if (row.querySelector('input[type="radio"]')?.checked) q.correctAnswer = q.options.length - 1; }
            });
        }
        if (type === 'multi-select') {
            q.options = []; q.correctAnswers = [];
            card.querySelectorAll('.opt-row').forEach(row => {
                const txt = row.querySelector('input[type="text"]')?.value?.trim();
                if (txt) { const i = q.options.length; q.options.push(txt); if (row.querySelector('input[type="checkbox"]')?.checked) q.correctAnswers.push(i); }
            });
        }
        if (type === 'written') {
            q.correctAnswerText = card.querySelector('[data-role="correctAnswerText"]')?.value?.trim() || '';
        }
        return q;
    }).filter(Boolean);
}
async function saveQuiz(quizType) {
    const isPlacement = quizType === 'placement', prefix = isPlacement ? 'pt' : 'lq';
    const title   = document.getElementById(`${prefix}-title`)?.value?.trim();
    const passing = parseInt(document.getElementById(`${prefix}-passing`)?.value) || 70;
    const level   = isPlacement ? null : document.getElementById('lq-level')?.value;
    if (!title)   { showToast('Please enter a quiz title', 'error'); return; }
    const questions = collectQuestions(prefix);
    if (!questions.length) { showToast('Add at least one question', 'error'); return; }
    const payload = { title, quizType: isPlacement ? 'placement' : 'level', passingScore: passing, questions };
    if (!isPlacement) payload.level = level;
    try {
        const res  = await fetch(`/courses/content/${COURSE_SLUG}/quiz/save`, { method:'POST', headers:{'Content-Type':'application/json'}, credentials:'include', body:JSON.stringify(payload) });
        const data = await res.json();
        if (data.success) { showToast('✓ Quiz saved successfully!', 'success'); setTimeout(() => location.reload(), 1200); }
        else showToast(data.message || 'Error saving quiz', 'error');
    } catch { showToast('Network error', 'error'); }
}
async function deleteQuiz(quizId) {
    if (!confirm('Delete this quiz? This cannot be undone.')) return;
    try {
        const res  = await fetch(`/courses/content/${COURSE_SLUG}/quiz/${quizId}`, { method:'DELETE', credentials:'include' });
        const data = await res.json();
        if (data.success) { showToast('Quiz deleted', 'success'); setTimeout(() => location.reload(), 900); }
        else showToast('Error deleting quiz', 'error');
    } catch { showToast('Error', 'error'); }
}
function showToast(msg, type) {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.className = `toast ${type} show`;
    setTimeout(() => t.classList.remove('show'), 3000);
}
</script>
</body>
</html>
