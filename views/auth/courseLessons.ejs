<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Course Lessons - <%= course.Title %></title>
    <link rel="stylesheet" href="/Style/courseLesson.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        .level-beginner {
            background: #10B981;
            color: white;
            padding: 2px 8px;
            border-radius: 12px;
            font-size: 12px;
            margin-left: 10px;
        }
        .level-intermediate {
            background: #F59E0B;
            color: white;
            padding: 2px 8px;
            border-radius: 12px;
            font-size: 12px;
            margin-left: 10px;
        }
        .level-advanced {
            background: #EF4444;
            color: white;
            padding: 2px 8px;
            border-radius: 12px;
            font-size: 12px;
            margin-left: 10px;
        }
        .lesson-level {
            display: inline-block;
            padding: 2px 8px;
            border-radius: 12px;
            font-size: 11px;
            margin-left: 10px;
        }
        .level-badge-beginner {
            background: #10B981;
            color: white;
        }
        .level-badge-intermediate {
            background: #F59E0B;
            color: white;
        }
        .level-badge-advanced {
            background: #EF4444;
            color: white;
        }
        .quiz-card {
            margin-top: 15px;
        }
    </style>
</head>
<body>

<div class="page-container">

    <!-- SIDEBAR -->
    <div class="sidebar">
        <div class="logo">
            <img src="/img/logoBleu.png" class="logo-img" alt="logo">
            <span>Eduphin</span>
        </div>

        <div class="menu">
            <ul>
                <li><a href="/teacherDashboard/get">Home</a></li>
                <li><a href="/profile/Profile-view">My Profile</a></li>
                <li><a href="/App/createQuiz">Create Quiz</a></li>
                <li><a href="/App/createCourse">Create Course</a></li>
                <li><a href="/App/studentAnalytics">Student Analytics</a></li>
            </ul>
        </div>

        <br><br><br><br><br>

        <a href="/home">
            <button class="logout"><i class="fas fa-sign-out-alt"></i> Sign out</button>
        </a>
    </div>

    <!-- MAIN -->
    <div class="main">

        <div class="main-header">
            <h2><%= course.Title %> - <span>Lessons</span></h2>
        </div>

        <div style="padding: 2rem;">

            <button class="back-btn" onclick="window.location.href='/teacherDashboard/get'">
                ← Back to Dashboard
            </button>

            <!-- LESSONS SECTION -->
            <div class="lessons-container">
                <h3>📚 Course Content</h3>

                <% if (course.lessons && course.lessons.length > 0) { %>

                    <% course.lessons.forEach((lesson, index) => { 
                        let levelClass = '';
                        let levelText = '';
                        if(lesson.level === 'beginner') {
                            levelClass = 'level-badge-beginner';
                            levelText = 'Beginner';
                        } else if(lesson.level === 'intermediate') {
                            levelClass = 'level-badge-intermediate';
                            levelText = 'Intermediate';
                        } else if(lesson.level === 'advanced') {
                            levelClass = 'level-badge-advanced';
                            levelText = 'Advanced';
                        }
                    %>

                        <div class="lesson-card">

                            <div class="lesson-title">
                                Lesson <%= index + 1 %>: <%= lesson.name %>
                                <span class="lesson-level <%= levelClass %>"><%= levelText %></span>
                            </div>

                            <div>
                                <span class="lesson-type <%= lesson.type === 'video' ? 'type-video' : 'type-pdf' %>">
                                    <%= lesson.type === 'video' ? '🎬 Video' : '📄 PDF' %>
                                </span>
                                <span class="lesson-duration">⏱️ <%= lesson.duration %></span>
                            </div>

                            <% if (lesson.file && lesson.file !== "") { %>
                                <div>
                                    <a href="<%= lesson.file %>" class="file-link" target="_blank">
                                        <%= lesson.type === 'video' ? '▶️ Watch Video' : '📖 Read PDF' %>
                                    </a>
                                </div>
                            <% } else { %>
                                <p style="color: #f59e0b;">⚠️ No file uploaded yet</p>
                            <% } %>

                        </div>

                    <% }) %>

                <% } else { %>

                    <div class="no-lessons">
                        <p>📚 No lessons added yet</p>
                        <a href="/courses/edit/<%= course.slug %>" class="file-link">
                            + Add Lessons
                        </a>
                    </div>

                <% } %>

            </div>

            <!-- QUIZZES SECTION -->
            <div class="lessons-container" style="margin-top:40px;">
                <h3>🧠 Course Quizzes</h3>
                
                <!-- Beginner Quizzes -->
                <% if(quizzesByLevel && quizzesByLevel.beginner && quizzesByLevel.beginner.length > 0) { %>
                    <h4 style="color: #10B981; margin-top: 20px;">🌱 Beginner Level Quizzes</h4>
                    <% quizzesByLevel.beginner.forEach((quiz, qIndex) => { %>
                        <div class="lesson-card quiz-card">
                            <div class="lesson-title">
                                📝 Quiz: <%= quiz.title %>
                                <span class="level-beginner">Beginner</span>
                            </div>
                            <div>Passing Score: <%= quiz.passingScore || 70 %>%</div>
                            <div>Questions: <%= quiz.questions?.length || 0 %></div>
                            <% if(quiz.questions && quiz.questions.length > 0) { %>
                                <details style="margin-top: 10px;">
                                    <summary style="cursor: pointer; color: #4F46E5;">View Questions</summary>
                                    <% quiz.questions.forEach((q, i) => { %>
                                        <div style="margin-top: 10px; padding: 10px; background: #f9fafb; border-radius: 8px;">
                                            <p><strong>Q<%= i + 1 %>:</strong> <%= q.question %></p>
                                            <ul style="margin-top: 5px; margin-bottom: 5px;">
                                                <% q.options.forEach((opt, oIndex) => { %>
                                                    <li>
                                                        <%= opt %>
                                                        <% if (oIndex === q.correctAnswer) { %>
                                                            <span style="color: green;"> ✔ (Correct)</span>
                                                        <% } %>
                                                    </li>
                                                <% }) %>
                                            </ul>
                                        </div>
                                    <% }) %>
                                </details>
                            <% } %>
                        </div>
                    <% }) %>
                <% } %>
                
                <!-- Intermediate Quizzes -->
                <% if(quizzesByLevel && quizzesByLevel.intermediate && quizzesByLevel.intermediate.length > 0) { %>
                    <h4 style="color: #F59E0B; margin-top: 20px;">⚡ Intermediate Level Quizzes</h4>
                    <% quizzesByLevel.intermediate.forEach((quiz, qIndex) => { %>
                        <div class="lesson-card quiz-card">
                            <div class="lesson-title">
                                📝 Quiz: <%= quiz.title %>
                                <span class="level-intermediate">Intermediate</span>
                            </div>
                            <div>Passing Score: <%= quiz.passingScore || 70 %>%</div>
                            <div>Questions: <%= quiz.questions?.length || 0 %></div>
                            <% if(quiz.questions && quiz.questions.length > 0) { %>
                                <details style="margin-top: 10px;">
                                    <summary style="cursor: pointer; color: #4F46E5;">View Questions</summary>
                                    <% quiz.questions.forEach((q, i) => { %>
                                        <div style="margin-top: 10px; padding: 10px; background: #f9fafb; border-radius: 8px;">
                                            <p><strong>Q<%= i + 1 %>:</strong> <%= q.question %></p>
                                            <ul style="margin-top: 5px; margin-bottom: 5px;">
                                                <% q.options.forEach((opt, oIndex) => { %>
                                                    <li>
                                                        <%= opt %>
                                                        <% if (oIndex === q.correctAnswer) { %>
                                                            <span style="color: green;"> ✔ (Correct)</span>
                                                        <% } %>
                                                    </li>
                                                <% }) %>
                                            </ul>
                                        </div>
                                    <% }) %>
                                </details>
                            <% } %>
                        </div>
                    <% }) %>
                <% } %>
                
                <!-- Advanced Quizzes -->
                <% if(quizzesByLevel && quizzesByLevel.advanced && quizzesByLevel.advanced.length > 0) { %>
                    <h4 style="color: #EF4444; margin-top: 20px;">🚀 Advanced Level Quizzes</h4>
                    <% quizzesByLevel.advanced.forEach((quiz, qIndex) => { %>
                        <div class="lesson-card quiz-card">
                            <div class="lesson-title">
                                📝 Quiz: <%= quiz.title %>
                                <span class="level-advanced">Advanced</span>
                            </div>
                            <div>Passing Score: <%= quiz.passingScore || 70 %>%</div>
                            <div>Questions: <%= quiz.questions?.length || 0 %></div>
                            <% if(quiz.questions && quiz.questions.length > 0) { %>
                                <details style="margin-top: 10px;">
                                    <summary style="cursor: pointer; color: #4F46E5;">View Questions</summary>
                                    <% quiz.questions.forEach((q, i) => { %>
                                        <div style="margin-top: 10px; padding: 10px; background: #f9fafb; border-radius: 8px;">
                                            <p><strong>Q<%= i + 1 %>:</strong> <%= q.question %></p>
                                            <ul style="margin-top: 5px; margin-bottom: 5px;">
                                                <% q.options.forEach((opt, oIndex) => { %>
                                                    <li>
                                                        <%= opt %>
                                                        <% if (oIndex === q.correctAnswer) { %>
                                                            <span style="color: green;"> ✔ (Correct)</span>
                                                        <% } %>
                                                    </li>
                                                <% }) %>
                                            </ul>
                                        </div>
                                    <% }) %>
                                </details>
                            <% } %>
                        </div>
                    <% }) %>
                <% } %>
                
                <% if(!quizzesByLevel || 
                      (!quizzesByLevel.beginner || quizzesByLevel.beginner.length === 0) && 
                      (!quizzesByLevel.intermediate || quizzesByLevel.intermediate.length === 0) && 
                      (!quizzesByLevel.advanced || quizzesByLevel.advanced.length === 0)) { %>
                    <div class="no-lessons">
                        <p>🧠 No quizzes added yet</p>
                        <a href="/App/createQuiz?courseId=<%= course._id %>" class="file-link">
                            + Add Quiz
                        </a>
                    </div>
                <% } %>
            </div>

            <!-- ADD QUIZ BUTTON -->
            <div style="margin-top: 20px; text-align: center;">
                <a href="/App/createQuiz?courseId=<%= course._id %>">
                    <button class="btn-create" style="background: #4F46E5;">
                        <i class="fas fa-plus"></i> Add New Quiz
                    </button>
                </a>
            </div>

        </div>

        <div class="footer">© 2026 Eduphin. All Rights Reserved.</div>

    </div>
</div>

</body>
</html>