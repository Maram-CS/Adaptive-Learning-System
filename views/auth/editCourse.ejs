<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Eduphin | Edit Course</title>
<link rel="stylesheet" href="/Style/createCourse.css">
</head>
<body>

<div class="page-container">

    <!-- SIDEBAR -->
    <div class="sidebar">
        <div class="logo">
            <img src="/img/logoBleu.png" class="logo-img">
            <span>Eduphin</span>
        </div>

        <div class="menu">
            <ul>
                <li class="active">Edit Course</li>
                <li><a href="/teacherDashboard/get">Home</a></li>
                <li><a href="/profile/Profile-view">My Profile</a></li>
                <li><a href="/App/createQuiz">Create Quiz</a></li>
                <li><a href="/App/studentAnalytics">Student Analytics</a></li>
            </ul>
        </div>

        <br><br><br><br><br>

        <a href="/home">
            <button class="logout">Sign out</button>
        </a>
    </div>

    <!-- MAIN -->
    <div class="main">

        <div class="main-header">
            <h2>Edit <span>Course</span></h2>
        </div>

        <br>

        <div style="padding: 0 2rem;">
            <h3><span class="orange">Edit</span> <span class="blue">Course</span></h3>
            <p class="breadcrumb">
                <a href="/teacherDashboard/get">Home</a> &rsaquo; Edit Course
            </p>
        </div>

        <div style="padding: 0 2rem 2rem;">

            <!-- FORM -->
            <form id="edit-course-form" action="/courses/edit/<%= course.slug %>" method="POST" enctype="multipart/form-data">

                <!-- BASIC INFO -->
                <div class="form-section">
                    <div class="form-section-title">Basic info</div>

                    <div class="field">
                        <label>Course Title *</label>
                        <input type="text" name="Title" value="<%= course.Title %>" required>
                    </div>

                    <div class="field">
                        <label>Description *</label>
                        <textarea name="Description" required><%= course.Description %></textarea>
                    </div>

                    <div class="field">
                        <label>Category *</label>
                        <select name="category" required>
                            <option value="frontend" <%= course.category === "frontend" ? "selected" : "" %>>Frontend</option>
                            <option value="backend" <%= course.category === "backend" ? "selected" : "" %>>Backend</option>
                            <option value="database" <%= course.category === "database" ? "selected" : "" %>>Database</option>
                            <option value="tools" <%= course.category === "tools" ? "selected" : "" %>>Tools</option>
                            <option value="design" <%= course.category === "design" ? "selected" : "" %>>Design</option>
                            <option value="deployment" <%= course.category === "deployment" ? "selected" : "" %>>Deployment</option>
                        </select>
                    </div>
                </div>

                <!-- DETAILS -->
                <div class="form-section">
                    <div class="form-section-title">Course details</div>

                    <div class="form-grid-3">

                        <div class="field">
                            <label>Level</label>
                            <select name="level">
                                <option value="beginner" <%= course.level === "beginner" ? "selected" : "" %>>Beginner</option>
                                <option value="intermediate" <%= course.level === "intermediate" ? "selected" : "" %>>Intermediate</option>
                                <option value="advanced" <%= course.level === "advanced" ? "selected" : "" %>>Advanced</option>
                            </select>
                        </div>

                        <div class="field">
                            <label>Total Duration</label>
                            <input type="text" name="totalDuration" value="<%= course.totalDuration %>">
                        </div>

                        <div class="field">
                            <label>Price (USD)</label>
                            <input type="number" name="price" value="<%= course.price %>">
                        </div>

                    </div>

                    <div class="field">
                        <label>Slug</label>
                        <input type="text" name="slug" value="<%= course.slug %>">
                    </div>
                </div>

                <!-- MEDIA -->
                <div class="form-section">
                    <div class="form-section-title">Media</div>

                    <div class="field">
                        <label>Course Thumbnail</label>

                        <div style="display:flex; gap:12px; align-items:center;">
                            <input type="file" name="image" accept="image/*">
                        </div>

                        <% if(course.image){ %>
                            <img src="<%= course.image %>" style="width:180px; margin-top:10px; border-radius:8px;">
                        <% } %>
                    </div>
                </div>

                <!-- VISIBILITY -->
                <div class="form-section">
                    <label>
                        <input type="checkbox" name="isPublished" <%= course.isPublished ? "checked" : "" %>>
                        Publish immediately
                    </label>
                </div>

                <!-- ACTIONS -->
                <div class="form-actions">
                    <button type="submit" class="btn-create">Update Course</button>
                </div>

            </form>

        </div>

        <div class="footer">© 2026 Eduphin. All Rights Reserved.</div>

    </div>
</div>

</body>
</html>

<script>
    // Auto slug from title
    document.getElementById('title').addEventListener('input', function () {
        document.getElementById('slug').value = this.value
            .toLowerCase()
            .replace(/[^a-z0-9]+/g, '-')
            .replace(/^-|-$/g, '');
        updatePreview();
    });

    // Image preview
    function previewImg() {
        const input = document.getElementById('image');
        const el    = document.getElementById('img-preview');
        const label = document.getElementById('file-name');

        if (input.files && input.files[0]) {
            const file = input.files[0];
            label.textContent = file.name;

            const reader = new FileReader();
            reader.onload = function(e) {
                el.style.backgroundImage    = 'url(' + e.target.result + ')';
                el.style.backgroundSize     = 'cover';
                el.style.backgroundPosition = 'center';
                el.innerHTML = '';
            };
            reader.readAsDataURL(file);
        } else {
            label.textContent = 'No file chosen';
            el.style.backgroundImage = '';
            el.innerHTML = '&#128247; Image preview';
        }
    }

    // Live preview JSON
    function updatePreview() {
        const obj = {
            Title:         document.getElementById('title').value || undefined,
            Description:   document.getElementById('description').value || undefined,
            category:      document.getElementById('category').value || undefined,
            totalDuration: document.getElementById('totalDuration').value || 'Coming soon',
            level:         document.getElementById('level').value,
            price:         parseFloat(document.getElementById('price').value) || 0,
            slug:          document.getElementById('slug').value || undefined,
            isPublished:   document.getElementById('isPublished').checked,
            chapters:      [],
            resources:     [],
            enrolledStudents: []
        };
        Object.keys(obj).forEach(k => obj[k] === undefined && delete obj[k]);
        console.log(JSON.stringify(obj, null, 2));
    }

    // Reset form
    function resetForm() {
        document.getElementById('title').value = '';
        document.getElementById('description').value = '';
        document.getElementById('totalDuration').value = '';
        document.getElementById('slug').value = '';
        document.getElementById('price').value = '0';
        document.getElementById('category').value = '';
        document.getElementById('isPublished').checked = true;
        document.getElementById('level').value = 'beginner';
        document.getElementById('file-name').textContent = 'No file chosen';
        document.getElementById('img-preview').style.backgroundImage = '';
        document.getElementById('img-preview').innerHTML = '&#128247; Image preview';
        updatePreview();
    }

    document.querySelectorAll('input, select, textarea').forEach(el => {
        el.addEventListener('input', updatePreview);
        el.addEventListener('change', updatePreview);
    });

    updatePreview();

    // Form submit via fetch
    document.getElementById('create-course-form').addEventListener('submit', function(e) {
        e.preventDefault();
        const formData = new FormData(this);
        fetch('/courses/create', {
            method: 'POST',
            body: formData
        })
        .then(res => res.json())
        .then(data => { alert('Course created!'); console.log(data); resetForm(); })
        .catch(err => { alert('Error creating course'); console.error(err); });
    });

    

</script>

<% if (typeof message !== "undefined") { %>
<script>
  alert("<%= message %>");
</script>
<% } %>

</body>
</html>