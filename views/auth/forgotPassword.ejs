<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Forgot Password - Eduphin</title>
    <link rel="stylesheet" href="/Style/Register.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
</head>
<body>

<div class="auth-wrapper">

    <!-- LEFT -->
    <div class="credentials-panel signin">
        <h2 class="slide-element">Forgot Password</h2>

        <form action="/auth/forgot-password" method="POST">

            <div class="field-wrapper slide-element">
                <input type="email" name="email" required placeholder=" ">
                <label>Email</label>
                <i class="fas fa-envelope"></i>
            </div>

            <button type="submit" class="submit-button slide-element">
                Send Reset Link
            </button>

            <div class="switch-link slide-element">
                <a href="/login">Back to Login</a>
            </div>

        </form>
    </div>

    <!-- RIGHT -->
    <div class="welcome-section signin">
        <h2 class="slide-element">Reset your password 🔐</h2>
        <p class="slide-element">
            Enter your email and we’ll help you recover your account.
        </p>
    </div>

</div>

<div class="footer">© 2026 Eduphin All Rights Reserved</div>

</body>
</html>