<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Eduphin | Create Course</title>
<link rel="stylesheet" href="/Style/createCourse.css">
</head>
<body>

<div class="page-container">

    <!-- SIDEBAR -->
    <div class="sidebar">
        <div class="logo">
            <img src="/img/logoBleu.png" class="logo-img">
            <span>Eduphin</span>
        </div>
        <div class="menu">
            <ul>
                <li class="active">Create Course</li>
                <li><a href="/teacherDashboard/get">Home</a></li>
                <li><a href="/profile/Profile-view">My Profile</a></li>
                <li><a href="/App/createQuiz">Create Quiz</a></li>
                <li><a href="/App/studentAnalystics">Student Analytics</a></li>
            </ul>
        </div>
        <br><br><br><br><br>
        <a href="/home">
            <button class="logout">Sign out</button>
        </a>
    </div>

    <!-- MAIN CONTENT -->
    <div class="main">

        <!-- HEADER -->
        <div class="main-header">
            <h2>Create <span>Course</span></h2>
        </div>

        <br>

        <!-- PAGE TITLE + BREADCRUMB -->
        <div style="padding: 0 2rem;">
            <h3><span class="orange">New</span> <span class="blue">Course</span></h3>
            <p class="breadcrumb">
                <a href="/teacherDashboard/get">Home</a> &rsaquo; Create Course
            </p>
        </div>

        <div style="padding: 0 2rem 2rem;">

            <!-- ── FORM START ── -->
            <form id="create-course-form" action="/courses/create" method="POST" enctype="multipart/form-data">

                <!-- ── BASIC INFO ── -->
                <div class="form-section">
                    <div class="form-section-title">Basic info</div>

                    <div class="field">
                        <label for="title">Course Title *</label>
                        <input type="text" id="title" name="Title" placeholder="Complete Node.js Bootcamp" required>
                    </div>

                    <div class="field">
                        <label for="description">Description *</label>
                        <textarea id="description" name="Description" placeholder="What will students learn?" required></textarea>
                    </div>

                    <div class="field">
                        <label for="category">Category *</label>
                        <select id="category" name="category" required>
                            <option value="" disabled selected>Select category</option>
                            <option value="frontend">Frontend</option>
                            <option value="backend">Backend</option>
                            <option value="database">Database</option>
                            <option value="tools">Tools</option>
                            <option value="design">Design</option>
                            <option value="deployment">Deployment</option>
                        </select>
                    </div>
                </div>

                <!-- ── COURSE DETAILS ── -->
                <div class="form-section">
                    <div class="form-section-title">Course details</div>

                    <div class="form-grid-3">
                        <div class="field">
                            <label>Level</label>
                            <select id="level" name="level" required>
                                <option value="beginner">Beginner</option>
                                <option value="intermediate">Intermediate</option>
                                <option value="advanced">Advanced</option>
                            </select>
                        </div>

                        <div class="field">
                            <label for="totalDuration">Total Duration</label>
                            <input type="text" id="totalDuration" name="totalDuration" placeholder="12h 30m">
                        </div>

                        <div class="field">
                            <label for="price">Price (USD)</label>
                            <input type="number" id="price" name="price" min="0" step="0.01" value="0">
                        </div>
                    </div>

                    <div class="field">
                        <label for="slug">Slug</label>
                        <input type="text" id="slug" name="slug" placeholder="auto-generated from title">
                    </div>
                </div>

                <!-- ── MEDIA ── -->
                <div class="form-section">
                    <div class="form-section-title">Media</div>

                    <div class="field">
                        <label>Course Thumbnail *</label>

                        <div style="display: flex; align-items: center; gap: 12px; flex-wrap: wrap;">
                            <label for="image" style="
                                display: inline-flex;
                                align-items: center;
                                gap: 8px;
                                padding: 8px 16px;
                                background: transparent;
                                border: 1px solid #ccc;
                                border-radius: 6px;
                                cursor: pointer;
                                font-size: 14px;
                                color: inherit;
                            ">
                                &#8593; Upload Image
                                <input type="file" id="image" name="image" accept="image/*" required
                                       style="display: none;" onchange="previewImg()">
                            </label>

                            <span id="file-name" style="font-size: 13px; color: #888;">No file chosen</span>
                        </div>

                        <!-- Image Preview -->
                        <div id="img-preview" style="
                            margin-top: 12px;
                            width: 180px;
                            height: 110px;
                            border: 1px dashed #ccc;
                            border-radius: 8px;
                            display: flex;
                            flex-direction: column;
                            align-items: center;
                            justify-content: center;
                            color: #aaa;
                            font-size: 13px;
                            gap: 6px;
                            overflow: hidden;
                        ">
                            &#128247; Image preview
                        </div>
                    </div>
                </div>

                <!-- ── VISIBILITY ── -->
                <div class="form-section">
                    <label>
                        <input type="checkbox" id="isPublished" name="isPublished" checked>
                        Publish immediately
                    </label>
                </div>

                <!-- ── ACTIONS ── -->
                <div class="form-actions">
                    <button type="reset" class="btn-reset" onclick="resetForm()">Reset</button>
                    <button type="submit" class="btn-create">Create Course</button>
                </div>

            </form>
            <!-- ── FORM END ── -->

        </div>

        <!-- FOOTER -->
        <div class="footer">© 2026 Eduphin. All Rights Reserved.</div>

    </div><!-- /main -->

</div><!-- /page-container -->

<script>
    // Auto slug from title
    document.getElementById('title').addEventListener('input', function () {
        document.getElementById('slug').value = this.value
            .toLowerCase()
            .replace(/[^a-z0-9]+/g, '-')
            .replace(/^-|-$/g, '');
        updatePreview();
    });

    // Image preview
    function previewImg() {
        const input = document.getElementById('image');
        const el    = document.getElementById('img-preview');
        const label = document.getElementById('file-name');

        if (input.files && input.files[0]) {
            const file = input.files[0];
            label.textContent = file.name;

            const reader = new FileReader();
            reader.onload = function(e) {
                el.style.backgroundImage    = 'url(' + e.target.result + ')';
                el.style.backgroundSize     = 'cover';
                el.style.backgroundPosition = 'center';
                el.innerHTML = '';
            };
            reader.readAsDataURL(file);
        } else {
            label.textContent = 'No file chosen';
            el.style.backgroundImage = '';
            el.innerHTML = '&#128247; Image preview';
        }
    }

    // Live preview JSON
    function updatePreview() {
        const obj = {
            Title:         document.getElementById('title').value || undefined,
            Description:   document.getElementById('description').value || undefined,
            category:      document.getElementById('category').value || undefined,
            totalDuration: document.getElementById('totalDuration').value || 'Coming soon',
            level:         document.getElementById('level').value,
            price:         parseFloat(document.getElementById('price').value) || 0,
            slug:          document.getElementById('slug').value || undefined,
            isPublished:   document.getElementById('isPublished').checked,
            chapters:      [],
            resources:     [],
            enrolledStudents: []
        };
        Object.keys(obj).forEach(k => obj[k] === undefined && delete obj[k]);
        console.log(JSON.stringify(obj, null, 2));
    }

    // Reset form
    function resetForm() {
        document.getElementById('title').value = '';
        document.getElementById('description').value = '';
        document.getElementById('totalDuration').value = '';
        document.getElementById('slug').value = '';
        document.getElementById('price').value = '0';
        document.getElementById('category').value = '';
        document.getElementById('isPublished').checked = true;
        document.getElementById('level').value = 'beginner';
        document.getElementById('file-name').textContent = 'No file chosen';
        document.getElementById('img-preview').style.backgroundImage = '';
        document.getElementById('img-preview').innerHTML = '&#128247; Image preview';
        updatePreview();
    }

    document.querySelectorAll('input, select, textarea').forEach(el => {
        el.addEventListener('input', updatePreview);
        el.addEventListener('change', updatePreview);
    });

    updatePreview();

    // Form submit via fetch
    document.getElementById('create-course-form').addEventListener('submit', function(e) {
        e.preventDefault();
        const formData = new FormData(this);
        fetch('/courses/create', {
            method: 'POST',
            body: formData
        })
        .then(res => res.json())
        .then(data => { alert('Course created!'); console.log(data); resetForm(); })
        .catch(err => { alert('Error creating course'); console.error(err); });
    });
</script>

<% if (typeof error !== "undefined") { %>
<script>
  alert("<%= error %>");
</script>
<% } %>

</body>
</html>