<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Favorite Courses - Eduphin</title>
  <link rel="stylesheet" href="/Style/favoriteCourses.css">
</head>
<body>

<div class="page-container">

  <!-- SIDEBAR -->
  <div class="sidebar">
    <div class="logo">
      <img src="/img/logoBleu.png" class="logo-img" alt="Eduphin logo" onerror="this.style.display='none'">
      <span>My Courses</span>
    </div>
    <div class="menu">
      <ul>
        <li><a href="/courses/All">All Courses</a></li>
        <li><a href="/App/studentDashboard">Dashboard</a></li>
        <li class="active"><a href="/App/favoriteCourses">Favorite Courses</a></li>
        <li><a href="/profile/Profile-view">My Profile</a></li>
      </ul>
    </div>
    <a href="/home"><button class="logout">Sign out</button></a>
  </div>

  <!-- MAIN -->
  <div class="main">

    <!-- Header -->
    <div class="main-header">
      <h2>Favorite <span>Courses</span></h2>
      <div class="header-actions">
        <input type="text" id="searchInput" class="search-bar" placeholder="Search favorites...">
        <div class="buttons">
          <button class="icon-btn">🔔</button>
          <button class="icon-btn">💬</button>
          <a href="/App/infoProfile"><button class="icon-btn">👤</button></a>
        </div>
      </div>
    </div>

    <!-- Stats Bar -->
    <div class="stats-bar">
      <div class="stat-pill">
        <span class="stat-icon">❤️</span>
        <span id="favCount">0</span> Saved
      </div>
      <div class="stat-pill">
        <span class="stat-icon">⭐</span>
        <span id="ratedCount">0</span> Rated
      </div>
      <button class="clear-all-btn" id="clearAllBtn" onclick="clearAllFavorites()">
        🗑️ Clear All
      </button>
    </div>

    <!-- Filter Buttons -->
    <div class="filter-buttons">
      <button onclick="filterFavorites('all', this)" class="active-filter">All</button>
      <button onclick="filterFavorites('frontend', this)">Frontend</button>
      <button onclick="filterFavorites('backend', this)">Backend</button>
      <button onclick="filterFavorites('database', this)">Database</button>
      <button onclick="filterFavorites('tools', this)">Tools</button>
      <button onclick="filterFavorites('design', this)">Design</button>
      <button onclick="filterFavorites('deployment', this)">Deployment</button>
    </div>

    <!-- Empty State -->
    <div class="empty-state" id="emptyState" style="display:none;">
      <div class="empty-icon">💔</div>
      <h3>No favorites yet</h3>
      <p>You haven't saved any courses. Browse all courses and click the heart icon to add them here.</p>
      <a href="/courses/All" class="browse-btn">Browse Courses</a>
    </div>

    <!-- Courses Grid -->
    <div class="courses-container" id="favoritesContainer"></div>

  </div>
</div>

<div class="footer">© 2026 Eduphin. All rights reserved.</div>

<!--
  All courses from the DB are injected here as JSON so the favorites page
  can look up any course by its slug — no hardcoded list needed.
  In your Express route, pass the courses array to the template:
    res.render('favoriteCourses', { courses });
-->
<script>
  // All courses from MongoDB, keyed by slug for fast lookup
  const allCourses = JSON.parse('<%- JSON.stringify(courses) %>');
  const courseBySlug = {};
  allCourses.forEach(c => { courseBySlug[c.slug] = c; });
</script>

<script>
/* ── RATING TEXT ────────────────────────────────────── */
const ratingText = { 0: 'Tap to rate', 1: 'Poor', 2: 'Fair', 3: 'Good', 4: 'Very Good', 5: 'Excellent! 🎉' };

/* ── GET / SET FAVORITES ────────────────────────────── */
function getFavorites() {
  try { return JSON.parse(localStorage.getItem('favorites') || '[]'); }
  catch { return []; }
}

function toggleFavorite(slug) {
  let favs = getFavorites();
  const idx = favs.indexOf(slug);
  if (idx === -1) { favs.push(slug); } else { favs.splice(idx, 1); }
  localStorage.setItem('favorites', JSON.stringify(favs));
  renderFavorites();
}

function clearAllFavorites() {
  if (!confirm('Remove all favorite courses?')) return;
  localStorage.setItem('favorites', '[]');
  renderFavorites();
}

/* ── STAR RATING ────────────────────────────────────── */
function buildStars(container) {
  const course = container.getAttribute('data-course');
  const saved  = parseInt(localStorage.getItem('rating_' + course)) || 0;
  const label  = container.nextElementSibling;
  container.innerHTML = '';

  for (let i = 1; i <= 5; i++) {
    const star = document.createElement('span');
    star.classList.add('star');
    star.textContent = '★';
    star.dataset.value = i;
    if (i <= saved) star.classList.add('filled');

    star.addEventListener('mouseenter', () => {
      highlightStars(container, i);
      label.textContent = ratingText[i];
      label.classList.remove('rated');
    });
    star.addEventListener('mouseleave', () => {
      const cur = parseInt(localStorage.getItem('rating_' + course)) || 0;
      highlightStars(container, cur);
      label.textContent = ratingText[cur];
      label.classList.toggle('rated', cur > 0);
    });
    star.addEventListener('click', () => {
      localStorage.setItem('rating_' + course, i);
      highlightStars(container, i);
      label.textContent = ratingText[i];
      label.classList.add('rated');
      star.style.transform = 'scale(1.6)';
      setTimeout(() => { star.style.transform = ''; }, 220);
      updateStats();
    });

    container.appendChild(star);
  }

  highlightStars(container, saved);
  label.textContent = ratingText[saved];
  label.classList.toggle('rated', saved > 0);
}

function highlightStars(container, value) {
  container.querySelectorAll('.star').forEach(s => {
    s.classList.toggle('filled', parseInt(s.dataset.value) <= value);
  });
}

/* ── UPDATE STATS ───────────────────────────────────── */
function updateStats() {
  const favs = getFavorites();
  document.getElementById('favCount').textContent = favs.length;
  let rated = 0;
  favs.forEach(slug => { if (parseInt(localStorage.getItem('rating_' + slug)) > 0) rated++; });
  document.getElementById('ratedCount').textContent = rated;
}

/* ── RENDER ─────────────────────────────────────────── */
function renderFavorites(category = 'all') {
  const container  = document.getElementById('favoritesContainer');
  const emptyState = document.getElementById('emptyState');
  const favs       = getFavorites();

  // Filter: must be in favorites AND exist in DB AND match category
  const filtered = favs
    .map(slug => courseBySlug[slug])
    .filter(c => c && (category === 'all' || c.category === category));

  container.innerHTML = '';

  if (favs.length === 0) {
    emptyState.style.display = 'flex';
    container.style.display  = 'none';
    updateStats();
    return;
  }

  emptyState.style.display = 'none';
  container.style.display  = 'flex';

  if (filtered.length === 0) {
    container.innerHTML = '<div class="no-results">No favorites in this category.</div>';
    updateStats();
    return;
  }

  filtered.forEach((course, i) => {
    const card = document.createElement('div');
    card.className = 'item';
    card.setAttribute('data-category', course.category);
    card.style.animationDelay = (i * 0.06) + 's';
    card.innerHTML = `
      <button class="heart-btn active" title="Remove from favorites" onclick="toggleFavorite('${course.slug}')">❤️</button>
      <img src="${course.image}" class="course-img" alt="${course.Title}" onerror="this.src='/img/default.png'">
      <h3>${course.Title}</h3>
      <span class="category-tag">${course.category}</span>
      <p>${course.Description}</p>
      <div class="card-divider"></div>
      <div class="star-rating" data-course="${course.slug}"></div>
      <div class="rating-label">Tap to rate</div>
      <button class="view-details-btn" onclick="viewCourseDetails('${course._id}')">View Details</button>
    `;
    container.appendChild(card);
  });

  container.querySelectorAll('.star-rating').forEach(buildStars);
  updateStats();
}

/* ── FILTER ─────────────────────────────────────────── */
function filterFavorites(category, btn) {
  document.querySelectorAll('.filter-buttons button').forEach(b => b.classList.remove('active-filter'));
  btn.classList.add('active-filter');
  renderFavorites(category);
}

/* ── SEARCH ─────────────────────────────────────────── */
document.getElementById('searchInput').addEventListener('keyup', function () {
  const filter = this.value.toLowerCase();
  document.querySelectorAll('#favoritesContainer .item').forEach(item => {
    item.style.display = item.textContent.toLowerCase().includes(filter) ? 'flex' : 'none';
  });
});

/* ── VIEW DETAILS ───────────────────────────────────── */
function viewCourseDetails(id) {
  localStorage.setItem('selectedCourse', id);
  window.location.href = '/App/course';
}

/* ── INIT ───────────────────────────────────────────── */
renderFavorites();
</script>

</body>
</html>
