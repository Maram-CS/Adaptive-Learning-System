<!-- views/auth/courseLearn.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= course.Title %> - Learning</title>
    <link rel="stylesheet" href="/Style/courseLearn.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>

<div class="learning-container">
    <!-- Sidebar -->
    <div class="learning-sidebar">
        <div class="logo">
            <img src="/img/logoBleu.png" class="logo-img">
            <span><%= course.Title %></span>
        </div>
        
        <!-- Level Progress -->
        <div class="level-progress-sidebar">
            <div class="level <%= currentLevel === 'beginner' ? 'active' : (levelProgress?.levels?.beginner?.quizPassed ? 'passed' : '') %>">
                <i class="fas fa-seedling"></i> Beginner
                <% if(levelProgress?.levels?.beginner?.quizPassed) { %><i class="fas fa-check-circle"></i><% } %>
            </div>
            <div class="level <%= currentLevel === 'intermediate' ? 'active' : (levelProgress?.levels?.intermediate?.quizPassed ? 'passed' : '') %>">
                <i class="fas fa-chart-line"></i> Intermediate
                <% if(levelProgress?.levels?.intermediate?.quizPassed) { %><i class="fas fa-check-circle"></i><% } %>
            </div>
            <div class="level <%= currentLevel === 'advanced' ? 'active' : (levelProgress?.levels?.advanced?.quizPassed ? 'passed' : '') %>">
                <i class="fas fa-rocket"></i> Advanced
                <% if(levelProgress?.levels?.advanced?.quizPassed) { %><i class="fas fa-check-circle"></i><% } %>
            </div>
        </div>
        
        <!-- Lessons List -->
        <div class="lessons-list">
            <h4><%= currentLevel.toUpperCase() %> Level Lessons</h4>
            <% currentLessons.forEach((lesson, idx) => { 
                const isCompleted = completedLessonIds.includes(lesson._id.toString());
            %>
                <div class="lesson-list-item <%= isCompleted ? 'completed' : '' %>" onclick="scrollToLesson('<%= lesson._id %>')">
                    <i class="fas <%= isCompleted ? 'fa-check-circle' : 'fa-circle' %>"></i>
                    <span>Lesson <%= idx + 1 %>: <%= lesson.name %></span>
                </div>
            <% }) %>
        </div>
        
        <a href="/course/<%= course.slug %>">
            <button class="back-to-course">
                <i class="fas fa-arrow-left"></i> Back to Course
            </button>
        </a>
    </div>
    
    <!-- Main Content -->
    <div class="learning-main">
        <div class="learning-header">
            <h1><%= course.Title %></h1>
            <div class="level-badge"><%= currentLevel %></div>
        </div>
        
        <!-- Lessons Content -->
        <div class="lessons-content">
            <% currentLessons.forEach((lesson, idx) => { 
                const isCompleted = completedLessonIds.includes(lesson._id.toString());
            %>
                <div id="lesson-<%= lesson._id %>" class="lesson-content-card <%= isCompleted ? 'completed' : '' %>">
                    <div class="lesson-header">
                        <h2>Lesson <%= idx + 1 %>: <%= lesson.name %></h2>
                        <span class="lesson-duration"><i class="fas fa-clock"></i> <%= lesson.duration %></span>
                    </div>
                    
                    <div class="lesson-body">
                        <% if(lesson.type === 'video') { %>
                            <video src="<%= lesson.file %>" controls class="lesson-video"></video>
                        <% } else { %>
                            <iframe src="<%= lesson.file %>" class="lesson-pdf"></iframe>
                        <% } %>
                    </div>
                    
                    <div class="lesson-footer">
                        <% if(!isCompleted) { %>
                            <button onclick="completeLesson('<%= lesson._id %>')" class="complete-lesson-btn">
                                <i class="fas fa-check"></i> Mark as Completed
                            </button>
                        <% } else { %>
                            <span class="completed-badge"><i class="fas fa-check-circle"></i> Completed</span>
                        <% } %>
                    </div>
                </div>
            <% }) %>
        </div>
        
        <!-- Quiz Section -->
        <% if(showQuiz && quiz) { %>
            <div class="quiz-section" id="quizSection">
                <div class="quiz-header">
                    <h2><i class="fas fa-puzzle-piece"></i> <%= quiz.title %></h2>
                    <p>Passing score: <%= quiz.passingScore || 70 %>%</p>
                </div>
                
                <form id="quizForm">
                    <input type="hidden" name="courseId" value="<%= course._id %>">
                    <input type="hidden" name="quizId" value="<%= quiz._id %>">
                    <input type="hidden" name="level" value="<%= currentLevel %>">
                    
                    <% quiz.questions.forEach((q, idx) => { %>
                        <div class="quiz-question">
                            <h4>Question <%= idx + 1 %>: <%= q.question %></h4>
                            <div class="quiz-options">
                                <% q.options.forEach((opt, optIdx) => { %>
                                    <label class="quiz-option">
                                        <input type="radio" name="answers[<%= idx %>]" value="<%= optIdx %>" required>
                                        <span><%= String.fromCharCode(65 + optIdx) %>. <%= opt %></span>
                                    </label>
                                <% }) %>
                            </div>
                        </div>
                    <% }) %>
                    
                    <button type="submit" class="submit-quiz-btn">
                        <i class="fas fa-paper-plane"></i> Submit Quiz
                    </button>
                </form>
                
                <div id="quizResult"></div>
            </div>
        <% } %>
    </div>
</div>

<script>
const courseId = '<%= course._id %>';

async function completeLesson(lessonId) {
    try {
        const response = await fetch('/api/complete-lesson', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ courseId, lessonId })
        });
        
        const data = await response.json();
        
        if(data.success) {
            if(data.allCompleted) {
                showMessage(data.message, 'success');
                // Scroll to quiz section
                document.getElementById('quizSection')?.scrollIntoView({ behavior: 'smooth' });
            } else {
                showMessage(data.message, 'success');
            }
            location.reload();
        }
    } catch(err) {
        showMessage('Error completing lesson', 'error');
    }
}

function scrollToLesson(lessonId) {
    document.getElementById(`lesson-${lessonId}`).scrollIntoView({ behavior: 'smooth' });
}

function showMessage(message, type) {
    const resultDiv = document.getElementById('quizResult');
    if(resultDiv) {
        resultDiv.innerHTML = `<div class="alert ${type}">${message}</div>`;
        setTimeout(() => {
            resultDiv.innerHTML = '';
        }, 3000);
    } else {
        alert(message);
    }
}

document.getElementById('quizForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const formData = new FormData(e.target);
    const answers = {};
    
    for(let [key, value] of formData.entries()) {
        if(key.startsWith('answers')) {
            const match = key.match(/\[(\d+)\]/);
            if(match) answers[match[1]] = value;
        }
    }
    
    const submitBtn = document.querySelector('.submit-quiz-btn');
    submitBtn.disabled = true;
    submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Submitting...';
    
    try {
        const response = await fetch('/api/submit-quiz', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                courseId: formData.get('courseId'),
                quizId: formData.get('quizId'),
                level: formData.get('level'),
                answers: answers
            })
        });
        
        const result = await response.json();
        const resultDiv = document.getElementById('quizResult');
        
        resultDiv.innerHTML = `
            <div class="alert ${result.passed ? 'success' : 'error'}">
                <i class="fas ${result.passed ? 'fa-trophy' : 'fa-sad-tear'}"></i>
                ${result.message}
            </div>
        `;
        
        if(result.passed) {
            setTimeout(() => {
                window.location.href = `/course/${'<%= course.slug %>'}/learn`;
            }, 3000);
        } else {
            submitBtn.disabled = false;
            submitBtn.innerHTML = '<i class="fas fa-paper-plane"></i> Submit Quiz';
        }
    } catch(err) {
        resultDiv.innerHTML = `<div class="alert error">Error submitting quiz: ${err.message}</div>`;
        submitBtn.disabled = false;
        submitBtn.innerHTML = '<i class="fas fa-paper-plane"></i> Submit Quiz';
    }
});
</script>

<style>
.learning-container {
    display: flex;
    height: 100vh;
}
.learning-sidebar {
    width: 300px;
    background: #1e1e2f;
    color: white;
    display: flex;
    flex-direction: column;
    overflow-y: auto;
}
.learning-main {
    flex: 1;
    overflow-y: auto;
    padding: 20px;
    background: #f5f5f5;
}
.level-progress-sidebar {
    padding: 20px;
}
.level {
    padding: 12px;
    margin-bottom: 10px;
    border-radius: 8px;
    background: #2a2a3a;
    cursor: pointer;
}
.level.active {
    background: #4F46E5;
}
.level.passed {
    background: #10B981;
}
.lessons-list {
    padding: 20px;
    border-top: 1px solid #333;
}
.lesson-list-item {
    padding: 10px;
    margin-bottom: 8px;
    border-radius: 6px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 10px;
}
.lesson-list-item:hover {
    background: #2a2a3a;
}
.lesson-list-item.completed {
    color: #10B981;
}
.lesson-content-card {
    background: white;
    border-radius: 12px;
    padding: 20px;
    margin-bottom: 20px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}
.lesson-content-card.completed {
    border-left: 4px solid #10B981;
}
.lesson-video {
    width: 100%;
    border-radius: 8px;
}
.lesson-pdf {
    width: 100%;
    height: 500px;
    border: none;
    border-radius: 8px;
}
.complete-lesson-btn {
    background: #4F46E5;
    color: white;
    border: none;
    padding: 10px 20px;
    border-radius: 8px;
    cursor: pointer;
}
.quiz-section {
    background: white;
    border-radius: 12px;
    padding: 20px;
    margin-top: 20px;
}
.quiz-question {
    background: #f9fafb;
    padding: 20px;
    border-radius: 8px;
    margin-bottom: 20px;
}
.quiz-options {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 15px;
}
.quiz-option {
    display: flex;
    align-items: center;
    gap: 10px;
    cursor: pointer;
}
.submit-quiz-btn {
    background: #10B981;
    color: white;
    border: none;
    padding: 12px 24px;
    border-radius: 8px;
    cursor: pointer;
    font-size: 16px;
}
.alert {
    padding: 15px;
    border-radius: 8px;
    margin-top: 20px;
}
.alert.success {
    background: #dcfce7;
    color: #166534;
}
.alert.error {
    background: #fee2e2;
    color: #b91c1c;
}
.back-to-course {
    margin: 20px;
    padding: 10px;
    background: #333;
    color: white;
    border: none;
    border-radius: 8px;
    cursor: pointer;
}
</style>

</body>
</html>