<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>My Profile - View</title>
  <link rel="stylesheet" href="/Style/Profile.css">
</head>
<body>

<div class="container">

  <!-- Sidebar -->
  <div class="sidebar">
    <h3 class="logo">My profile</h3>

    <ul>
      <li class="active">My profile</li>
      <li>Home</li>
      <li>My courses</li>
      <li>Dashboard</li>
    </ul>

    <button class="logout">Sign out</button>
  </div>

  <!-- Main Content -->
  <div class="main">

    <h2>Student <span>Profile</span></h2>

    <!-- عرض البيانات -->
    <div class="profile-view">
      
      <!-- صورة المستخدم والـ Bio (عرض فقط) -->
      <div class="profile-header">
        <div class="profile-info">
          <div class="avatar-container">
            <img id="profileImage" class="avatar" src="https://via.placeholder.com/90" alt="Profile">
          </div>
          
          <div class="user-details">
            <div class="username-input" style="background-color: #f1f5f9; border-color: #cbd5e0; color: #2d3748; display: flex; align-items: center;">frontend developer</div>
            <div class="bio-value">Frontend developer passionate about creating beautiful and responsive web applications</div>
          </div>
        </div>

        <div class="header-buttons">
          <button class="edit-button" onclick="window.location.href='/App/profile'">Edit Profile</button>
        </div>
      </div>
      
      <!-- Personal Information Box (عرض فقط) -->
      <div class="info-box">
        <div class="box-header">
          <h3 class="box-title">Personal Information</h3>
          <span class="box-icon">👤</span>
        </div>
        <div class="box-content">
          <div class="row">
            <div class="input-group">
              <label>First Name</label>
              <div class="info-value">John</div>
            </div>

            <div class="input-group">
              <label>Last Name</label>
              <div class="info-value">Doe</div>
            </div>
          </div>

          <div class="input-group">
            <label>User Name</label>
            <div class="info-value">johndoe123</div>
          </div>

          <div class="row">
            <div class="input-group">
              <label>Email Address</label>
              <div class="info-value">john.doe@example.com</div>
            </div>

            <div class="input-group">
              <label>Phone Number</label>
              <div class="info-value">+1 234 567 890</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Skills & Track Box (عرض فقط) -->
      <div class="info-box">
        <div class="box-header">
          <h3 class="box-title">Skills & Track</h3>
          <span class="box-icon">⚡️</span>
        </div>
        <div class="box-content">
          <div class="row">
            <div class="input-group">
              <label>Main track</label>
              <div class="info-value">Frontend Development</div>
            </div>

            <div class="input-group">
              <label>Skill level</label>
              <div class="info-value">Advanced</div>
            </div>
          </div>
        </div>
      </div>

    </div>

  </div>

</div>

</body>
</html>