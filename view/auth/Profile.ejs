<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Student Profile</title>
  <link rel="stylesheet" href="/Style/Profile.css">
</head>
<body>

<div class="container">

  <!-- Sidebar -->
  <div class="sidebar">
    <h3 class="logo">My profile</h3>

    <ul>
      <li class="active">My profile</li>
      <li>Home</li>
      <li>My courses</li>
      <li>Dashboard</li>
    </ul>

    <button class="logout">Sign out</button>
  </div>

  <!-- Main Content -->
  <div class="main">

    <h2>Student <span>Profile</span></h2>

    <div class="profile-header">
      <div class="profile-info">
        <div class="avatar-container">
          <img id="profileImage" class="avatar" src="https://via.placeholder.com/90" alt="Profile">
          <input type="file" name="profilePicture" id="imageUpload" accept="image/*" style="display: none;">
        </div>
        
        <div class="user-details">
          <input type="text" name="userName" class="username-input" placeholder="Enter username">
          <textarea name="bio" class="bio-input" placeholder="Write a short bio..."></textarea>
        </div>
      </div>

      <div class="header-buttons">
        <button type="button" class="upload" onclick="document.getElementById('imageUpload').click();">Upload New Photo</button>
        <button type="button" class="delete" id="deleteImage">Delete</button>
      </div>
    </div>

    <!-- Profile Form -->
    <form class="profile-form" method="POST" action="/profile/create" enctype="multipart/form-data">
      
      <!-- Personal Information Box -->
      <div class="info-box">
        <div class="box-header">
          <h3 class="box-title">Personal Information</h3>
          <span class="box-icon">👤</span>
        </div>
        <div class="box-content">
          <div class="row">
            <div class="input-group">
              <label>First Name</label>
              <input type="text" name="firstName" placeholder="Enter first name">
            </div>

            <div class="input-group">
              <label>Last Name</label>
              <input type="text" name="lastName" placeholder="Enter last name">
            </div>
          </div>

          <div class="input-group">
            <label>User Name</label>
            <input type="text" name="userName" placeholder="Enter username">
          </div>

          <div class="row">
            <div class="input-group">
              <label>Email Address</label>
              <input type="email" name="email" placeholder="Enter email">
            </div>

            <div class="input-group">
              <label>Phone Number</label>
              <input type="text" name="PhoneNumber" placeholder="Enter phone number">
            </div>
          </div>
        </div>
      </div>

      <!-- Academic Information Box -->
      <div class="info-box">
        <div class="box-header">
          <h3 class="box-title">Academic Information</h3>
          <span class="box-icon">🎓</span>
        </div>
        <div class="box-content">
          <div class="input-group">
            <label>University</label>
            <input type="text" name="university" placeholder="Enter university">
          </div>

          <div class="row">
            <div class="input-group">
              <label>Speciality</label>
              <select name="specialty">
                <option value="">- Select specialty -</option>
                <option>Computer Science</option>
                <option>Software Engineering</option>
                <option>Information Technology</option>
                <option>Data Science</option>
                <option>Artificial Intelligence</option>
                <option>Cybersecurity</option>
                <option>Other</option>
              </select>
            </div>

            <div class="input-group">
              <label>Year of study</label>
              <select name="yearOfStudy">
                <option value="">- Select year of study -</option>
                <option>1st Year</option>
                <option>2nd Year</option>
                <option>3rd Year</option>
                <option>4th Year</option>
                <option>Master's</option>
                <option>PhD</option>
                <option>Other</option>
              </select>
            </div>
          </div>
        </div>
      </div>

      <!-- Skills & Track Box -->
      <div class="info-box">
        <div class="box-header">
          <h3 class="box-title">Skills & Track</h3>
          <span class="box-icon">⚡</span>
        </div>
        <div class="box-content">
          <div class="row">
            <div class="input-group">
              <label>Main track</label>
              <select name="mainTrack">
                <option value="">- Select main track -</option>
                <option>Web Development</option>
                <option>Mobile Development</option>
                <option>Frontend Development</option>
                <option>Backend Development</option>
                <option>Full Stack Development</option>
                <option>DevOps</option>
                <option>Cloud Computing</option>
                <option>Other</option>
              </select>
            </div>

            <div class="input-group">
              <label>Skill level</label>
              <select name="skillLevel">
                <option value="">- Select skill level -</option>
                <option>Beginner</option>
                <option>Intermediate</option>
                <option>Advanced</option>
                <option>Expert</option>
              </select>
            </div>
          </div>
        </div>
      </div>

      <!-- Form buttons -->
      <div class="form-buttons">
        <button type="button" class="cancel">Cancel</button>
        <button type="submit" class="save">Save</button>
      </div>

    </form>

  </div>
</div>
<div class="footer">
    © 2026 Eduphin. All rights reserved.
</div>
<script>
  // Image preview
  document.getElementById('imageUpload').addEventListener('change', function(event) {
    const file = event.target.files[0];
    if (file) {
      const reader = new FileReader();
      reader.onload = function(e) {
        document.getElementById('profileImage').src = e.target.result;
      }
      reader.readAsDataURL(file);
    }
  });

  // Delete image
  document.getElementById('deleteImage').addEventListener('click', function() {
    document.getElementById('profileImage').src = 'https://via.placeholder.com/90';
    document.getElementById('imageUpload').value = '';
  });
</script>

</body>
</html>