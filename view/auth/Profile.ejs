
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Profile</title>
    <link rel="stylesheet" href="/Style/Profile.css">
</head>
<body>
    <div class="profile-container">
       
        <div class="box">
            <div class="box-header">
                <h3>Profile Photo</h3>
            </div>
            <div class="box-content photo-content">
                <div class="student-name">frontend developer</div>
                <div class="photo-actions">
                    <button class="upload-btn">Upload New Photo</button>
                    <button class="delete-btn">Delete</button>
                </div>
            </div>
        </div>

       
        <div class="box">
            <div class="box-header">
                <h3>Personal Information</h3>
            </div>
            <div class="box-content">
                <div class="form-row">
                    <div class="form-group">
                        <label>First Name</label>
                        <input type="text" placeholder="First Name">
                    </div>
                    <div class="form-group">
                        <label>Last Name</label>
                        <input type="text" placeholder="Last Name">
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Email Address</label>
                        <input type="email" placeholder="Email">
                    </div>
                    <div class="form-group">
                        <label>Phone Number</label>
                        <input type="tel" placeholder="Phone Number">
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Username</label>
                        <input type="text" placeholder="Username">
                    </div>
                </div>
            </div>
        </div>

        <!-- Academic Information Box -->
        <div class="box">
            <div class="box-header">
                <h3>Academic Information</h3>
            </div>
            <div class="box-content">
                <div class="form-row">
                    <div class="form-group full-width">
                        <label>University</label>
                        <input type="text" placeholder="University">
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Speciality</label>
                        <select>
                            <option>- select specialty -</option>
                            <option>Computer Science</option>
                            <option>Engineering</option>
                            <option>Medicine</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Year of Study</label>
                        <select>
                            <option>- select year of study -</option>
                            <option>1st Year</option>
                            <option>2nd Year</option>
                            <option>3rd Year</option>
                        </select>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Main Track</label>
                        <select>
                            <option>- select main truck -</option>
                            <option>Web Development</option>


<option>Data Science</option>
                            <option>Mobile Development</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Skill Level</label>
                        <select>
                            <option>- select skill level -</option>
                            <option>Beginner</option>
                            <option>Intermediate</option>
                            <option>Advanced</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <!-- Action Buttons: Cancel & Save -->
        <div class="action-buttons">
            <button class="cancel-btn">Cancel</button>
            <button class="save-btn">Save</button>
        </div>

        <!-- Sign Out Button -->
        <button class="signout-btn">Sign out</button>
    </div>
</body>
</html>